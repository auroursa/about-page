const drawerCategoryLinkClass = 'flex min-h-10 items-center justify-between rounded-full border border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] bg-[var(--card-content-color)] px-4 py-2 text-[0.95rem] text-[var(--text-color)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[var(--main-color)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_14%,var(--card-color))] hover:text-[var(--main-color)]';
