---
import { getCollection } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  currentPath?: string;
}

const { title, description = '赤茶的个人页面', ogImage = '/img/banner.webp', currentPath = '/' } = Astro.props;
const posts = await getCollection('blog');
const drawerCategories = [...new Set(posts.map((post) => post.data.category).filter(Boolean))].sort();
const drawerCategoryCounts = drawerCategories.map((category) => ({
  name: category,
  count: posts.filter((post) => post.data.category === category).length,
}));

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = 'https://cynosura.one';

const isActive = (path: string) => currentPath === path;
const currentSectionLabel = currentPath === '/'
  ? '首页'
  : currentPath === '/posts'
    ? '文章'
    : currentPath === '/friends'
      ? '友人'
      : currentPath === '/about'
        ? '关于'
        : '页面';
const currentSectionIconBody = currentPath === '/'
  ? '<path d="M17.8913288,10 L11.8900003,3.99867157 L5.88867192,10 L5.89001465,10 L5.89001465,20 L17.8900146,20 L17.8900146,10 L17.8913288,10 Z M19.8900146,11.9986859 L19.8900146,20 C19.8900146,21.1045695 18.9945841,22 17.8900146,22 L5.89001465,22 C4.78544515,22 3.89001465,21.1045695 3.89001465,20 L3.89001465,11.9986573 L2.41319817,13.4754737 L1,12.0622756 L10.4769858,2.5852898 C11.2573722,1.8049034 12.5226285,1.8049034 13.3030149,2.5852898 L22.7800007,12.0622756 L21.3668025,13.4754737 L19.8900146,11.9986859 Z" fill-rule="evenodd"></path>'
