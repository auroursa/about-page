const drawerSectionTitleClass = 'mb-3 text-left text-[0.78rem] font-bold tracking-[0.18em] text-[var(--main-color)]';
const drawerSectionHeaderClass = 'mb-3 flex items-start justify-between gap-3';
const drawerActionIconClass = 'inline-flex h-9 w-9 shrink-0 items-center justify-center text-[var(--main-color)] transition-colors duration-300 hover:text-[var(--accent-color)]';
const drawerHeaderActionIconClass = 'inline-flex h-9 w-9 shrink-0 items-start justify-center pt-0.5 text-[var(--main-color)] transition-colors duration-300 hover:text-[var(--accent-color)]';
const mainClass = 'mx-auto grid grid-cols-1 bg-[var(--bg-color)] max-w-[80%] min-[1800px]:max-w-[65%] max-[1280px]:max-w-[85%] max-[576px]:max-w-full';
---

<html lang="zh-cn">
  <head>
    <meta charset="utf-8" />
    <title>{title} - Cynosura</title>
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#EBF4F4" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#121212" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} - Cynosura`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={siteURL + ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@astraorsa" />
    <meta name="twitter:title" content={`${title} - Cynosura`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={siteURL + ogImage} />

    <link rel="me" href="https://diff.network/@ursa" />
    <script src="/js/nav-indicator.js" defer></script>
    <script src="/js/nav-sticky-menu.js" defer></script>
    <script src="/js/nav-drawer-menu.js" defer></script>
    <script src="/js/about-color-swatches.js" defer></script>
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
    <link rel="me" href="https://mastodon.social/@cynosura" />
    <link rel="me" href="https://octans.app/@cynosura" />
    <Font cssVariable="--font-overpass" preload />
    <Font cssVariable="--font-overpass-mono" preload />
  </head>
  <body>
    <header class="sticky top-8 z-[-1] mx-8 my-8 text-center font-overpass">
      <img class="mx-auto h-24 w-24 rounded-full" src="/img/avatar.webp" width="600" height="600" alt="site-avatar" />
      <h1 class="mx-auto my-[0.8rem] text-[2em] font-bold font-overpass">Cynosura</h1>
      <p class="m-0">Trying to light up the dark.</p>
    </header>

    <main class={mainClass}>
      <div class="menu-sentinel h-px"></div>

      <nav transition:animate="none" class="menu sticky z-20 flex items-center justify-center">
        <div class="absolute left-4 top-1/2 hidden -translate-y-1/2 items-center max-[768px]:hidden min-[769px]:flex">
          <a href="/" class="desktop-nav-brand-shell rounded-xl px-3 py-2 transition-colors duration-300 hover:bg-[color:color-mix(in_srgb,var(--text-color)_6%,transparent)]">
            <img class="desktop-nav-brand-avatar h-7 w-7 shrink-0 rounded-lg object-cover" src="/img/avatar.webp" width="600" height="600" alt="site-avatar" />
          </a>
        </div>

        <div class="desktop-nav-links flex items-center gap-0.5 max-[768px]:hidden">
          <div class="desktop-nav-core relative flex items-center gap-0.5">
            <div class="nav-indicator absolute rounded-xl border border-[color:color-mix(in_srgb,var(--main-color)_24%,transparent)] bg-[color:color-mix(in_srgb,var(--main-color)_26%,var(--card-color))] shadow-[0_8px_20px_rgba(17,101,154,0.18)] pointer-events-none" style="top: 0; left: 0; height: 0; width: 0; opacity: 0;"></div>
            <a href="/" class:list={[menuButtonBase, isActive('/') && menuButtonActive]} aria-labelledby="menu-a-index">
