const menuButtonActive = 'nav-active-btn text-[color:color-mix(in_srgb,var(--main-color)_78%,white)] hover:bg-transparent';
const menuIconClass = 'h-[1.1rem] w-[1.1rem] fill-current transition-colors duration-300';
const menuLabelClass = 'transition-colors duration-300';
const menuLabelActiveClass = 'text-[color:color-mix(in_srgb,var(--main-color)_78%,white)] drop-shadow-[0_1px_6px_rgba(81,168,221,0.18)]';
const menuIconActiveClass = 'text-[color:color-mix(in_srgb,var(--main-color)_78%,white)] drop-shadow-[0_1px_6px_rgba(81,168,221,0.18)]';
const mobileMenuButtonClass = 'inline-flex h-9 w-9 shrink-0 items-center justify-center bg-transparent text-[var(--text-color)] transition-colors duration-300 hover:text-[var(--main-color)]';
const drawerCurrentPillClass = 'inline-flex items-center rounded-full bg-[color:color-mix(in_srgb,var(--main-color)_14%,var(--card-color))] px-2.5 py-1 text-[0.72rem] font-bold tracking-[0.14em] text-[var(--main-color)]';
const drawerIconButtonClass = 'inline-flex min-h-11 w-full items-center justify-center rounded-[1rem] border border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] bg-[var(--card-content-color)] text-[var(--text-color)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[var(--main-color)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_14%,var(--card-color))] hover:text-[var(--main-color)]';
const drawerPillClass = 'inline-flex min-h-11 items-center justify-center rounded-[1rem] border border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] bg-[var(--card-content-color)] px-4 py-2 text-[var(--text-color)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[var(--main-color)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_14%,var(--card-color))] hover:text-[var(--main-color)]';
const drawerNavLinkBase = 'group flex min-h-[5.4rem] flex-col justify-between rounded-[1.25rem] border border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] bg-[var(--card-content-color)] px-4 py-3 text-[var(--text-color)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[var(--main-color)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_14%,var(--card-color))] hover:text-[var(--main-color)]';
