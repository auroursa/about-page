---
import { getCollection } from 'astro:content';
import { ClientRouter, fade } from 'astro:transitions';
import { Image, Font } from 'astro:assets';
import avatar from '../assets/img/avatar.webp';
import profileAvatar from '../assets/img/profile-avatar.webp';
import AstroNavigateBridge from '../components/AstroNavigateBridge.astro';
import { getCategoryItems } from '../utils/categories';
import type { CategoryItem } from '../utils/categories';
import { socialIconLinks } from '../data/social-links';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  currentPath?: string;
  drawerCategories?: CategoryItem[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbTitle?: string;
}

const { title, description = '赤茶的个人页面', ogImage = '/img/banner.webp', currentPath = '/', drawerCategories: externalCategories, jsonLd, breadcrumbTitle } = Astro.props;
const drawerCategoryCounts = externalCategories ?? getCategoryItems(await getCollection('blog'));
const mainTransitionDuration = 'var(--page-main-transition-duration, 0.5s)';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = Astro.site?.origin ?? 'https://cynosura.one';

const navLabels: Record<string, string> = { '/': '首页', '/posts': '文章', '/friends': '友人', '/about': '关于' };
const breadcrumbItems: { name: string; url: string }[] = [{ name: '首页', url: siteURL }];
if (currentPath && currentPath !== '/') {
  const sectionLabel = navLabels[currentPath];
  if (sectionLabel) {
    breadcrumbItems.push({ name: sectionLabel, url: `${siteURL}${currentPath}` });
  }
}
if (breadcrumbTitle) {
  breadcrumbItems.push({ name: breadcrumbTitle, url: canonicalURL.toString() });
}
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
};

const allJsonLd = [breadcrumbLd, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];

const isActive = (path: string) => currentPath === path;

interface NavItem {
  path: string;
  label: string;
  labelEn: string;
  id: string;
  iconBody: string;
}

const navItems: NavItem[] = [
  { path: '/', label: '首页', labelEn: 'HOME', id: 'index', iconBody: '<path d="M17.8913288,10 L11.8900003,3.99867157 L5.88867192,10 L5.89001465,10 L5.89001465,20 L17.8900146,20 L17.8900146,10 L17.8913288,10 Z M19.8900146,11.9986859 L19.8900146,20 C19.8900146,21.1045695 18.9945841,22 17.8900146,22 L5.89001465,22 C4.78544515,22 3.89001465,21.1045695 3.89001465,20 L3.89001465,11.9986573 L2.41319817,13.4754737 L1,12.0622756 L10.4769858,2.5852898 C11.2573722,1.8049034 12.5226285,1.8049034 13.3030149,2.5852898 L22.7800007,12.0622756 L21.3668025,13.4754737 L19.8900146,11.9986859 Z" fill-rule="evenodd"></path>' },
  { path: '/posts', label: '文章', labelEn: 'POSTS', id: 'posts', iconBody: '<path d="M12.3023235,7.94519388 L4.69610276,15.549589 C4.29095108,15.9079238 4.04030835,16.4092335 4,16.8678295 L4,20.0029438 L7.06398288,20.004826 C7.5982069,19.9670062 8.09548693,19.7183782 8.49479322,19.2616227 L16.0567001,11.6997158 L12.3023235,7.94519388 Z M13.7167068,6.53115006 L17.4709137,10.2855022 L19.8647941,7.89162181 C19.9513987,7.80501747 20.0000526,7.68755666 20.0000526,7.56507948 C20.0000526,7.4426023 19.9513987,7.32514149 19.8647932,7.23853626 L16.7611243,4.13485646 C16.6754884,4.04854589 16.5589355,4 16.43735,4 C16.3157645,4 16.1992116,4.04854589 16.1135757,4.13485646 L13.7167068,6.53115006 Z M16.43735,2 C17.0920882,2 17.7197259,2.26141978 18.1781068,2.7234227 L21.2790059,5.82432181 C21.7406843,6.28599904 22.0000526,6.91216845 22.0000526,7.56507948 C22.0000526,8.21799052 21.7406843,8.84415992 21.2790068,9.30583626 L9.95750718,20.6237545 C9.25902448,21.4294925 8.26890003,21.9245308 7.1346,22.0023295 L2,22.0023295 L2,21.0023295 L2.00324765,16.7873015 C2.08843822,15.7328366 2.57866679,14.7523321 3.32649633,14.0934196 L14.6953877,2.72462818 C15.1563921,2.2608295 15.7833514,2 16.43735,2 Z" fill-rule="evenodd"></path>' },
  { path: '/friends', label: '友人', labelEn: 'FRIENDS', id: 'friends', iconBody: '<path d="M16.4341517,5.34027649 C19.5526401,4.82550436 21.9775728,5.30066885 22.7613144,6.98140814 C23.5450164,8.66206251 22.3504571,10.824965 19.951836,12.8828831 C19.5123956,16.8857302 16.1198862,20 12,20 C10.359675,20 8.83465517,19.5063199 7.56541555,18.6594348 C4.44608523,19.1746732 2.02039254,18.6996452 1.23650448,17.0185919 C0.452540248,15.3373751 1.64816139,13.1735876 4.04839101,11.1150512 C4.48877158,7.11319839 7.88082257,4 12,4 C13.6401386,4 15.1649982,4.49356789 16.4341517,5.34027649 Z M18.3526801,7.13687265 C19.0478987,8.04366602 19.553342,9.10361155 19.8096504,10.2573495 C20.759634,9.23569807 21.1931253,8.35081879 20.9486988,7.82664467 C20.7041658,7.30224176 19.7469377,7.06554811 18.3526801,7.13687265 Z M5.64723739,16.8630198 C4.95168113,15.9557542 4.44609504,14.8951833 4.1899293,13.7407574 C3.23872065,14.7632088 2.80454268,15.6488575 3.04912005,16.1733553 C3.29377581,16.6980213 4.25184178,16.9346893 5.64723739,16.8630198 Z M17.998801,11.8788388 C17.9342721,8.62105818 15.2732265,6 12,6 C8.6862915,6 6,8.6862915 6,12 C6,13.8017545 6.79417414,15.4180196 8.05156374,16.5178367 C9.61918795,16.1740501 11.4219878,15.5791568 13.2667642,14.7189234 C15.1123744,13.8583012 16.727532,12.8591526 17.998801,11.8788388 Z M17.3040733,14.8073455 C16.3274273,15.4175193 15.2552552,15.9984306 14.1120008,16.5315389 C12.9695057,17.0642931 11.8360704,17.5119809 10.7415499,17.8678087 C11.1473536,17.9544194 11.5683538,18 12,18 C14.2994717,18 16.2968203,16.7064576 17.3040733,14.8073455 Z" fill-rule="evenodd"></path>' },
  { path: '/about', label: '关于', labelEn: 'ABOUT', id: 'about', iconBody: '<path d="M12,23 C5.92486775,23 1,18.0751322 1,12 C1,5.92486775 5.92486775,1 12,1 C18.0751322,1 23,5.92486775 23,12 C23,18.0751322 18.0751322,23 12,23 Z M12,21 C16.9705627,21 21,16.9705627 21,12 C21,7.02943725 16.9705627,3 12,3 C7.02943725,3 3,7.02943725 3,12 C3,16.9705627 7.02943725,21 12,21 Z M13.0036109,13.9983464 L14.0029544,13.9983464 L14.0029544,15.9983464 L10.0029544,15.9983464 L10.0029544,13.9983464 L11.0029544,13.9983464 L11.0029544,11.9983464 L10.0029544,11.9983464 L10.0029544,9.99834639 L13.0036109,9.99834639 L13.0036109,13.9983464 Z M12.0003283,8.99834639 C11.4478622,8.99834639 11,8.55063114 11,7.99834639 C11,7.44606164 11.4478622,6.99834639 12.0003283,6.99834639 C12.5527943,6.99834639 13.0006565,7.44606164 13.0006565,7.99834639 C13.0006565,8.55063114 12.5527943,8.99834639 12.0003283,8.99834639 Z" fill-rule="evenodd"></path>' },
];

const currentNav = navItems.find((item) => item.path === currentPath) ?? navItems[0];
const currentSectionLabel = currentNav.label;
const currentSectionIconBody = currentNav.iconBody;

const menuButtonBase = 'relative inline-flex h-10 cursor-pointer items-center justify-center gap-2 rounded-xl bg-transparent px-3.5 text-[0.92rem] font-medium text-[var(--text-color)] transition-[background-color,color] duration-300 hover:bg-[color:color-mix(in_srgb,var(--text-color)_6%,transparent)]';
const menuButtonActive = 'nav-active-btn text-[var(--main-color)] hover:bg-transparent';
const menuIconClass = 'h-[1.1rem] w-[1.1rem] fill-current transition-colors duration-300 [transform:translateZ(0)]';
const menuLabelClass = 'transition-colors duration-300';
const menuLabelActiveClass = 'text-[var(--main-color)]';
const menuIconActiveClass = 'text-[var(--main-color)]';
const drawerNavLinkBase = 'drawer-interactive group flex min-h-[5.4rem] flex-col justify-between px-4 py-3';
const drawerNavLinkActive = 'bg-[color:color-mix(in_srgb,var(--main-color)_6%,var(--card-color))] text-[var(--main-color)]';
const drawerCategoryLinkClass = 'drawer-interactive flex min-h-10 items-center justify-between px-4 py-2 text-[0.95rem]';
const mainClass = 'mx-auto grid grid-cols-1 bg-[var(--bg-color)] max-w-[80%] min-[1800px]:max-w-[65%] max-[1280px]:max-w-[85%] max-[576px]:max-w-full';
---

<html lang="zh-cn">
  <head>
    <meta charset="utf-8" />
    <title>{title} - Cynosura</title>
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#EBF4F4" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#121212" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} - Cynosura`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={siteURL + ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@astraorsa" />
    <meta name="twitter:title" content={`${title} - Cynosura`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={siteURL + ogImage} />

    {allJsonLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <link rel="me" href="https://diff.network/@ursa" />
    <script src="/js/layout-settled.js" defer data-cfasync="false"></script>
    <script src="/js/nav-indicator.js" defer data-cfasync="false"></script>
    <script src="/js/nav-sticky-menu.js" defer data-cfasync="false"></script>
    <script src="/js/nav-drawer-menu.js" defer data-cfasync="false"></script>
    <script src="/js/page-skeleton.js" defer data-cfasync="false"></script>
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
    <link rel="me" href="https://mastodon.social/@cynosura" />
    <link rel="me" href="https://octans.app/@cynosura" />
    <Font cssVariable="--font-overpass" preload />
    <Font cssVariable="--font-overpass-mono" preload />
  </head>
  <body>
    <header transition:persist transition:animate="none" class="sticky top-8 z-[-1] mx-8 my-8 text-center font-overpass">
      <Image class="mx-auto h-24 w-24 rounded-full" style="max-width:96px;max-height:96px" src={avatar} widths={[96, 192]} sizes="96px" alt="" loading="eager" />
      <h1 class="mx-auto my-[0.8rem] text-[2em] font-bold font-overpass">Cynosura</h1>
      <p class="m-0">Trying to light up the dark.</p>
    </header>

    <main class={mainClass}>
      <div class="menu-sentinel h-px"></div>

      <nav transition:animate="none" class="menu sticky z-20 flex items-center justify-center">
        <div class="absolute left-4 top-1/2 hidden -translate-y-1/2 items-center max-[1280px]:hidden min-[1281px]:flex">
          <a href="/" class="desktop-nav-brand-shell rounded-xl px-3 py-2 transition-colors duration-300 hover:bg-[color:color-mix(in_srgb,var(--text-color)_6%,transparent)]" aria-label="返回首页">
            <Image class="desktop-nav-brand-avatar h-7 w-7 shrink-0 rounded-lg object-cover" src={avatar} widths={[28, 56]} sizes="28px" alt="" />
          </a>
        </div>

        <div class="desktop-nav-links flex items-center gap-0.5 max-[1280px]:hidden">
          <div class="desktop-nav-core relative flex items-center gap-0.5">
            <div class="nav-indicator absolute rounded-xl border border-[color:color-mix(in_srgb,var(--main-color)_18%,transparent)] bg-[color:color-mix(in_srgb,var(--main-color)_14%,var(--card-color))] shadow-[0_4px_12px_rgba(17,101,154,0.1)] pointer-events-none" style="top: 0; left: 0; height: 0; width: 0; opacity: 0;"></div>
            {navItems.map((nav) => (
              <a href={nav.path} class:list={[menuButtonBase, isActive(nav.path) && menuButtonActive]} aria-labelledby={`menu-a-${nav.id}`} data-astro-prefetch="hover">
                <svg class:list={[menuIconClass, isActive(nav.path) && menuIconActiveClass]} viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" set:html={nav.iconBody}></svg>
                <span class:list={[menuLabelClass, isActive(nav.path) && menuLabelActiveClass]} id={`menu-a-${nav.id}`}>{nav.label}</span>
              </a>
            ))}
          </div>
          <a href="https://www.travellings.cn/go.html" class:list={[menuButtonBase, 'desktop-nav-inline-travel']} aria-label="开往" title="开往" data-astro-reload>
            <svg class={menuIconClass} viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8.5" cy="14.5" r="1.5"></circle><circle cx="15.5" cy="14.5" r="1.5"></circle><path d="M18.87 3.34A3.55 3.55 0 0 0 16.38 2H7.62a3.47 3.47 0 0 0-2.5 1.35A4.32 4.32 0 0 0 4 6v12a1 1 0 0 0 1 1h2l-2 3h2.32L8 21h8l.68 1H19l-2-3h2a1 1 0 0 0 1-1V6a4.15 4.15 0 0 0-1.13-2.66zM7.62 4h8.72a1.77 1.77 0 0 1 1 .66 3.25 3.25 0 0 1 .25.34H6.39a2.3 2.3 0 0 1 .25-.35A1.65 1.65 0 0 1 7.62 4zM6 8V7h12v3H6zm12 9H6v-5h12z"></path></svg>
            <span class:list={[menuLabelClass, 'desktop-nav-inline-travel-label']}>开往</span>
          </a>
        </div>

        <div class="hidden w-full items-center justify-between max-[1280px]:flex">
          <a href="/" class="mobile-nav-brand-shell inline-flex items-center justify-center overflow-hidden" aria-label="返回首页">
            <Image class="mobile-nav-brand-avatar h-8 w-8 shrink-0 rounded-[0.8rem] object-cover" src={avatar} widths={[32, 64]} sizes="32px" alt="" />
          </a>

          <a href={currentPath} class="mobile-nav-current relative flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 transition-colors duration-200 hover:bg-[color:color-mix(in_srgb,var(--text-color)_6%,transparent)] active:bg-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)]">
            <svg class="h-[1.05rem] w-[1.05rem] shrink-0 fill-[var(--text-color)]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" set:html={currentSectionIconBody}></svg>
            <h2 class="mobile-nav-title m-0 whitespace-nowrap text-[1rem] font-semibold leading-none">{currentSectionLabel}</h2>
          </a>

          <button class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-[0.9rem] bg-transparent text-[var(--text-color)] transition-all duration-300 hover:scale-[1.03] hover:bg-[color:color-mix(in_srgb,var(--text-color)_8%,transparent)] active:scale-[0.92] active:bg-[color:color-mix(in_srgb,var(--text-color)_12%,transparent)]" id="open-menu" type="button" aria-label="打开菜单" aria-expanded="false" aria-controls="drawer">
            <svg class="h-[1.2rem] w-[1.2rem]" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.1" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><line x1="3" x2="21" y1="12" y2="12"></line><line x1="3" x2="21" y1="6" y2="6"></line><line x1="3" x2="21" y1="18" y2="18"></line></svg>
          </button>
        </div>
      </nav>

      <div id="drawer" role="dialog" aria-modal="true" aria-label="菜单" class="menu-b-drawer-container fixed inset-0 z-30 hidden bg-[rgb(0_0_0_/_0)] transition-[visibility,background-color] duration-300 ease-out max-[1280px]:block max-[1280px]:invisible max-[1280px]:pointer-events-none [&.open]:visible [&.open]:pointer-events-auto [&.open]:bg-[rgb(0_0_0_/_0.25)]">
        <div id="drawer-backdrop" class="menu-b-drawer-backdrop pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 ease-out"></div>
        <div class="flex h-full justify-end">
          <div id="drawer-panel" class="relative flex h-full w-[88%] max-w-[26rem] translate-x-full flex-col overflow-hidden bg-[var(--bg-color)] shadow-[-8px_0_32px_rgba(0,0,0,0.12)] transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] [&.open]:translate-x-0">
            <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgb(81_168_221_/_0.2),_transparent_42%)]"></div>

            <div class="drawer-scroll-content relative flex-1 overflow-y-auto px-4 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
              <section class="drawer-stagger relative mb-2 overflow-hidden border border-[color:color-mix(in_srgb,var(--text-color)_8%,transparent)] bg-[linear-gradient(160deg,color-mix(in_srgb,var(--main-color)_12%,var(--card-color))_0%,var(--card-color)_58%,color-mix(in_srgb,var(--accent-color)_10%,var(--card-color))_100%)] px-5 py-5 shadow-[0_18px_36px_rgba(17,101,154,0.12)]">
                <div class="pointer-events-none absolute -right-10 -top-10 h-28 w-28 rounded-full bg-[color:color-mix(in_srgb,var(--accent-color)_26%,transparent)] blur-2xl"></div>
                <div class="relative flex items-start justify-between gap-4">
                  <div class="flex min-w-0 items-center gap-4">
                    <Image
                      class="h-16 w-16 rounded-full object-cover"
                      src={profileAvatar}
                      widths={[96, 192]}
                      sizes="64px"
                      alt=""
                    />
                    <div class="min-w-0">
                      <h2 class="m-0 truncate text-[1.6rem] font-bold leading-none">赤茶</h2>
                      <p class="m-0 mt-1.5 text-[0.82rem] text-[color:color-mix(in_srgb,var(--text-color)_56%,transparent)] font-overpass">cynosura.one</p>
                    </div>
                  </div>
                  <button class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-[color:color-mix(in_srgb,var(--text-color)_46%,transparent)] transition-all duration-300 hover:text-[var(--main-color)] hover:scale-105 active:scale-90" id="close-menu" aria-label="关闭菜单">
                    <svg class="h-[1.5rem] w-[1.5rem] fill-current" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M437.5,386.6L306.9,256l130.6-130.6c14.1-14.1,14.1-36.8,0-50.9c-14.1-14.1-36.8-14.1-50.9,0L256,205.1L125.4,74.5c-14.1-14.1-36.8-14.1-50.9,0c-14.1,14.1-14.1,36.8,0,50.9L205.1,256L74.5,386.6c-14.1,14.1-14.1,36.8,0,50.9c14.1,14.1,36.8,14.1,50.9,0L256,306.9l130.6,130.6c14.1,14.1,36.8,14.1,50.9,0C451.5,423.4,451.5,400.6,437.5,386.6z"></path></svg>
                  </button>
                </div>

                <div class="relative mt-4 flex items-center justify-between gap-3">
                  <p class="m-0 text-sm text-[color:color-mix(in_srgb,var(--text-color)_72%,transparent)]">Per aspera, ad astra.</p>
                  <a href="https://www.travellings.cn/go.html" class="drawer-action-icon" aria-label="开往" title="开往">
                    <svg class="h-[1.25rem] w-[1.25rem] fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8.5" cy="14.5" r="1.5"></circle><circle cx="15.5" cy="14.5" r="1.5"></circle><path d="M18.87 3.34A3.55 3.55 0 0 0 16.38 2H7.62a3.47 3.47 0 0 0-2.5 1.35A4.32 4.32 0 0 0 4 6v12a1 1 0 0 0 1 1h2l-2 3h2.32L8 21h8l.68 1H19l-2-3h2a1 1 0 0 0 1-1V6a4.15 4.15 0 0 0-1.13-2.66zM7.62 4h8.72a1.77 1.77 0 0 1 1 .66 3.25 3.25 0 0 1 .25.34H6.39a2.3 2.3 0 0 1 .25-.35A1.65 1.65 0 0 1 7.62 4zM6 8V7h12v3H6zm12 9H6v-5h12z"></path></svg>
                  </a>
                </div>
              </section>

              <div class="relative space-y-2">
                <section class="drawer-stagger drawer-section">
                  <div class="drawer-section-header">
                    <h3 class="drawer-section-title mb-0">导航</h3>
                    <span class="inline-flex h-9 w-9 shrink-0" aria-hidden="true"></span>
                  </div>
                  <div class="grid grid-cols-2 gap-2">
                    {navItems.map((nav) => (
                      <a href={nav.path} class:list={[drawerNavLinkBase, isActive(nav.path) && drawerNavLinkActive]} data-astro-prefetch="hover">
                        <span class="text-[0.72rem] font-bold tracking-[0.16em] text-[color:color-mix(in_srgb,currentColor_60%,transparent)] font-overpass">{nav.labelEn}</span>
                        <div class="mt-4 flex items-end justify-between gap-3">
                          <span class="text-[1.15rem] font-bold leading-none">{nav.label}</span>
                          <svg class="h-[1.15rem] w-[1.15rem] fill-current transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" set:html={nav.iconBody}></svg>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>

                <section class="drawer-stagger drawer-section">
                  <div class="drawer-section-header">
                    <h3 class="drawer-section-title mb-0">文章分类</h3>
                    <a href="/rss.xml" class="drawer-action-icon items-start pt-0.5" aria-label="RSS 订阅" title="RSS 订阅" data-astro-reload>
                      <svg class="h-[1.1rem] w-[1.1rem] fill-current" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><circle cx="12.36" cy="35.64" r="4.36"></circle><path d="M8 8.89v5.66c14.06 0 25.46 11.4 25.46 25.46h5.66C39.11 22.82 25.18 8.89 8 8.89zM8 20.2v5.66c7.81 0 14.14 6.34 14.14 14.14h5.66c0-10.93-8.87-19.8-19.8-19.8z"></path></svg>
                    </a>
                  </div>
                  <div class="grid grid-cols-1 gap-2">
                    {drawerCategoryCounts.map((category) => (
                      <a href={`/posts/category/${encodeURIComponent(category.name)}`} class={drawerCategoryLinkClass}>
                        <span>{category.name}</span>
                        <span class="text-sm text-[color:color-mix(in_srgb,currentColor_72%,transparent)]">{category.count}</span>
                      </a>
                    ))}
                  </div>
                </section>

                <section class="drawer-stagger drawer-section">
                  <div class="drawer-section-header">
                    <h3 class="drawer-section-title mb-0">联系方式</h3>
                    <a href="https://keys.openpgp.org/vks/v1/by-fingerprint/F6006874CC50A6C854B9763C3728385536F22DEA" class="drawer-action-icon items-start pt-0.5" aria-label="OpenPGP" title="OpenPGP">
                      <svg class="h-[1.1rem] w-[1.1rem] fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><g><path d="M0 0h24v24H0z" fill="none"></path><path d="M10.758 11.828l7.849-7.849 1.414 1.414-1.414 1.415 2.474 2.474-1.414 1.415-2.475-2.475-1.414 1.414 2.121 2.121-1.414 1.415-2.121-2.122-2.192 2.192a5.002 5.002 0 0 1-7.708 6.294 5 5 0 0 1 6.294-7.708zm-.637 6.293A3 3 0 1 0 5.88 13.88a3 3 0 0 0 4.242 4.242z"></path></g></svg>
                    </a>
                  </div>
                  <div class="space-y-2">
                    <div class="grid grid-cols-4 gap-2">
                      {socialIconLinks.map((link) => (
                        <a
                          class="drawer-interactive inline-flex min-h-11 w-full items-center justify-center"
                          href={link.url}
                          title={link.title}
                          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                        >
                          <svg class="h-[1.15rem] w-[1.15rem] fill-current" viewBox={link.viewBox} xmlns="http://www.w3.org/2000/svg" set:html={link.iconBody}></svg>
                        </a>
                      ))}
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                      <a class="drawer-interactive inline-flex min-h-11 items-center justify-center px-4 py-2" href="https://t.me/looprucha" target="_blank" rel="noopener noreferrer">Telegram</a>
                      <a class="drawer-interactive inline-flex min-h-11 items-center justify-center px-4 py-2" href="https://matrix.to/#/@froseiun:matrix.org" target="_blank" rel="noopener noreferrer">Matrix</a>
                    </div>
                  </div>
                </section>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="page-transition-shell" transition:name="page-content-shell" transition:animate={fade({ duration: mainTransitionDuration })}>
        <slot />
      </div>
    </main>

    <footer transition:animate="none" class="mx-8 my-8 text-center font-overpass">
      <p>Designed by <a href="https://cynosura.one">Cynosura</a> &copy;&nbsp;{new Date().getFullYear()}</p>
    </footer>
    <AstroNavigateBridge />
  </body>
</html>
