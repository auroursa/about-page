---
import { getCollection, render } from 'astro:content';
import DecoratedTitle from '../../components/DecoratedTitle.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, toISODatetime } from '../../utils/date';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { entry: post },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const panelClass = 'glass-panel';
const articlePanelClass = 'space-y-6';
const panelTitleClass = 'mb-4 border-b border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] pb-2 !pl-0 text-[0.98rem] font-bold tracking-[0.08em] text-[var(--main-color)] before:hidden';
const detailRowClass = 'flex items-baseline gap-4 border-b border-[color:color-mix(in_srgb,var(--text-color)_6%,transparent)] py-2.5 last:border-b-0 last:pb-0 first:pt-0 max-[576px]:flex-col max-[576px]:gap-0.5';
const detailLabelClass = 'w-[5rem] shrink-0 text-[0.78rem] font-bold tracking-[0.16em] text-[var(--main-color)]';
const detailValueClass = 'text-[0.92rem] text-[color:color-mix(in_srgb,var(--text-color)_78%,transparent)]';
const categoryPillClass = 'category-pill';
const contentClass = 'prose-measure text-[1rem] leading-8 [&>*:first-child]:mt-0 [&>*:last-child]:mb-0 [&_h1]:text-[2em] [&_h1]:font-bold [&_h2]:mt-12 [&_h2]:border-t [&_h2]:border-[color:color-mix(in_srgb,var(--text-color)_8%,transparent)] [&_h2]:pt-8 [&_h2]:text-center [&_h2]:text-[1.5em] [&_h2]:font-bold [&_h3]:mt-9 [&_h3]:text-center [&_h3]:text-[1.17em] [&_h3]:font-bold [&_h4]:mt-8 [&_h4]:text-center [&_h4]:text-[1em] [&_h4]:font-bold [&_p]:my-5 [&_ul]:my-5 [&_ul]:list-disc [&_ul]:pl-10 [&_ol]:my-5 [&_ol]:list-decimal [&_ol]:pl-10 [&_pre]:my-6 [&_figure]:my-6 [&_blockquote]:my-6 [&_img]:mx-auto [&_img]:max-h-[35rem] [&_a]:text-[var(--main-color)] [&_a]:underline [&_a]:underline-offset-[0.18em] [&_hr]:my-8 [&_hr]:border-0 [&_hr]:border-t [&_hr]:border-[color:color-mix(in_srgb,var(--text-color)_8%,transparent)]';
const licenseIconsClass = 'flex items-center gap-2.5 text-[color:color-mix(in_srgb,var(--text-color)_60%,transparent)]';
const commentShellClass = 'bg-[var(--card-color)] p-4 text-[var(--text-color)]';
const canonicalPostUrl = new URL(Astro.url.pathname, Astro.site).toString();

const postDate = entry.data.pubDate || entry.data.date;
const blogPostingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  url: canonicalPostUrl,
  ...(postDate ? { datePublished: new Date(postDate).toISOString() } : {}),
  ...(entry.data.category ? { articleSection: entry.data.category } : {}),
  author: { '@type': 'Person', name: '赤茶', url: 'https://cynosura.one/about' },
  publisher: { '@type': 'Person', name: '赤茶', url: 'https://cynosura.one/about' },
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} ogImage={`/og/${entry.id}.png`} currentPath="/posts" jsonLd={blogPostingLd} breadcrumbTitle={entry.data.title}>
  <article class:list={[panelClass, articlePanelClass, 'mb-2']}>
      <header class="py-6">
        <h1 class="m-0 text-center text-[2.15rem] font-bold leading-[1.18] max-[576px]:text-[1.8rem]">{entry.data.title}</h1>
      </header>
      <div class={contentClass}>
        <Content />
      </div>
    </article>

    <div class="mb-2 grid grid-cols-2 gap-2 max-[576px]:grid-cols-1">
      <section class:list={[panelClass, 'h-full space-y-4']}>
        <DecoratedTitle as="h3" class={panelTitleClass}>本文信息</DecoratedTitle>
        <div>
          <div class={detailRowClass}>
            <span class={detailLabelClass}>作者</span>
            <span class={detailValueClass}>赤茶</span>
          </div>
          <div class={detailRowClass}>
            <span class={detailLabelClass}>发布时间</span>
            <time class:list={[detailValueClass, 'published']} datetime={toISODatetime(postDate)}>
              {formatDate(postDate)}
            </time>
          </div>
          {entry.data.category && (
            <div class={detailRowClass}>
              <span class={detailLabelClass}>文章分类</span>
              <span class={detailValueClass}>{entry.data.category}</span>
            </div>
          )}
          <div class={detailRowClass}>
            <span class={detailLabelClass}>链接</span>
            <a href={`/posts/${entry.id}`} title={entry.data.title} class:list={[detailValueClass, 'break-all text-[var(--main-color)] underline underline-offset-[0.18em]']}>
              {canonicalPostUrl}
            </a>
          </div>
        </div>
      </section>

      <section class:list={[panelClass, 'flex h-full flex-col space-y-4']}>
        <DecoratedTitle as="h3" class={panelTitleClass}>版权许可</DecoratedTitle>
        <div class="space-y-3 text-[0.92rem] text-[color:color-mix(in_srgb,var(--text-color)_78%,transparent)] [&>p]:m-0 [&>p]:leading-7">
          <p class="m-0 text-[0.95rem] font-bold">本文采用 <a rel="license" href="https://creativecommons.org/licenses/by-sa/4.0" target="_blank" title="Creative Commons Attribution-ShareAlike 4.0 International License">CC BY-SA 4.0</a> 协议授权</p>
          <p>保留署名与相同方式共享即可转载、引用或再创作。转载时请注明出处并附上本文链接。</p>
        </div>
        <div class="mt-auto! pt-2">
          <div class={licenseIconsClass}>
            <svg class="inline h-7 w-7 fill-current" viewBox="0 0 96 96" xmlns="http://www.w3.org/2000/svg"><g><path d="M47.358,0.004C20.85,0.357-0.351,22.133,0.004,48.641c0.354,26.507,22.129,47.71,48.637,47.354 c26.506-0.354,47.71-22.129,47.354-48.638C95.642,20.85,73.862-0.352,47.358,0.004z M48.506,85.892 c-20.928,0.279-38.119-16.459-38.398-37.388C9.829,27.578,26.567,10.387,47.493,10.107C68.42,9.828,85.61,26.564,85.891,47.492 C86.17,68.421,69.432,85.61,48.506,85.892z M36.254,56.132c-2.027,0-3.562-0.738-4.602-2.219c-1.041-1.479-1.559-3.45-1.559-5.915 c0-5.42,2.053-8.131,6.16-8.131c0.82,0,1.711,0.273,2.668,0.82c0.957,0.549,1.766,1.508,2.424,2.875l6.16-3.203 c-2.463-4.436-6.545-6.654-12.24-6.654c-3.889,0-7.104,1.287-9.648,3.861c-2.547,2.574-3.822,6.051-3.822,10.432 c0,4.491,1.262,7.997,3.779,10.517s5.834,3.777,9.941,3.777c2.572,0,4.928-0.645,7.062-1.93c2.135-1.287,3.807-3.053,5.012-5.299 l-5.67-2.876C40.825,54.817,38.936,56.132,36.254,56.132z M62.786,56.132c-2.027,0-3.561-0.738-4.6-2.219 c-1.041-1.479-1.561-3.45-1.561-5.915c0-5.42,2.053-8.131,6.16-8.131c0.875,0,1.793,0.273,2.75,0.82 c0.959,0.549,1.768,1.508,2.426,2.875l6.076-3.203c-2.41-4.436-6.461-6.654-12.156-6.654c-3.889,0-7.105,1.287-9.652,3.861 c-2.545,2.574-3.816,6.051-3.816,10.432c0,4.491,1.244,7.997,3.736,10.517c2.49,2.52,5.818,3.777,9.98,3.777 c2.518,0,4.846-0.645,6.98-1.93c2.135-1.287,3.832-3.053,5.094-5.299l-5.75-2.876C67.358,54.817,65.467,56.132,62.786,56.132z"></path></g></svg>
            <svg class="inline h-7 w-7 fill-current" viewBox="0 0 496 512" xmlns="http://www.w3.org/2000/svg"><path d="M314.9 194.4v101.4h-28.3v120.5h-77.1V295.9h-28.3V194.4c0-4.4 1.6-8.2 4.6-11.3 3.1-3.1 6.9-4.7 11.3-4.7H299c4.1 0 7.8 1.6 11.1 4.7 3.1 3.2 4.8 6.9 4.8 11.3zm-101.5-63.7c0-23.3 11.5-35 34.5-35s34.5 11.7 34.5 35c0 23-11.5 34.5-34.5 34.5s-34.5-11.5-34.5-34.5zM247.6 8C389.4 8 496 118.1 496 256c0 147.1-118.5 248-248.4 248C113.6 504 0 394.5 0 256 0 123.1 104.7 8 247.6 8zm.8 44.7C130.2 52.7 44.7 150.6 44.7 256c0 109.8 91.2 202.8 203.7 202.8 103.2 0 202.8-81.1 202.8-202.8.1-113.8-90.2-203.3-202.8-203.3z"></path></svg>
            <svg class="inline h-7 w-7 fill-current" viewBox="0 0 496 512" xmlns="http://www.w3.org/2000/svg"><path d="M247.6 8C389.4 8 496 118.1 496 256c0 147.1-118.5 248-248.4 248C113.6 504 0 394.5 0 256 0 123.1 104.7 8 247.6 8zm.8 44.7C130.2 52.7 44.7 150.6 44.7 256c0 109.8 91.2 202.8 203.7 202.8 103.2 0 202.8-81.1 202.8-202.8.1-113.8-90.2-203.3-202.8-203.3zM137.7 221c13-83.9 80.5-95.7 108.9-95.7 99.8 0 127.5 82.5 127.5 134.2 0 63.6-41 132.9-128.9 132.9-38.9 0-99.1-20-109.4-97h62.5c1.5 30.1 19.6 45.2 54.5 45.2 23.3 0 58-18.2 58-82.8 0-82.5-49.1-80.6-56.7-80.6-33.1 0-51.7 14.6-55.8 43.8h18.2l-49.2 49.2-49-49.2h19.4z"></path></svg>
          </div>
        </div>
      </section>
    </div>

    <section class:list={[panelClass, 'space-y-4']}>
      <DecoratedTitle as="h3" class={panelTitleClass}>评论</DecoratedTitle>
      <p class="mb-3 mt-0 text-[0.92rem] leading-7 text-[color:color-mix(in_srgb,var(--text-color)_68%,transparent)]">留言系统基于 <a href="https://disqus.com">Disqus</a>，部分网络环境可能无法正常加载。</p>
      <div class={commentShellClass}>
        <div id="disqus_thread" data-page-url={canonicalPostUrl} data-page-identifier={entry.id}></div>
      </div>
    </section>

  <script src="/js/post-disqus.js" data-astro-rerun data-cfasync="false"></script>
</BaseLayout>
