---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import PostSidebar from '../../components/PostSidebar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortPostsByDate } from '../../utils/date';
import { getCategoryItems } from '../../utils/categories';

const allPosts = await getCollection('blog');
const sortedPosts = sortPostsByDate(allPosts);
const categoryItems = getCategoryItems(sortedPosts);
---

<BaseLayout title="文章" description="博客文章列表" ogImage="/og/page/posts.png" currentPath="/posts" drawerCategories={categoryItems}>
  <div class="grid grid-cols-[1fr_3fr] items-start gap-2 max-[1280px]:grid-cols-1">
    <PostSidebar categories={categoryItems} />

    <div class="grid grid-cols-1 gap-2">
      {sortedPosts.map((post) => (
        <PostCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          pubDate={post.data.pubDate}
          date={post.data.date}
        />
      ))}
    </div>
  </div>
</BaseLayout>
