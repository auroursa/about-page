---
import { getCollection } from 'astro:content';
import PostSidebar from '../../components/PostSidebar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter((post) => post.data.pubDate || post.data.date)
  .sort((a, b) => {
    const dateStrA = (a.data.pubDate || a.data.date) as string;
    const dateStrB = (b.data.pubDate || b.data.date) as string;
    const parseDate = (str: string) => {
      const match = str.match(/(\d{4})-(\d{2})-(\d{2})/);
      if (!match) return new Date(0);
      return new Date(`${match[1]}-${match[2]}-${match[3]}T00:00:00+08:00`);
    };
    return parseDate(dateStrB).valueOf() - parseDate(dateStrA).valueOf();
  });

const categories = [...new Set(sortedPosts.map((post) => post.data.category).filter(Boolean))];
const categoryItems = categories.map((category) => ({
  name: category,
  count: sortedPosts.filter((post) => post.data.category === category).length,
}));

const formatDate = (dateStr: string | undefined) => {
  if (!dateStr) return '';
  const match = dateStr.match(/(\d{4})-(\d{2})-(\d{2})/);
  if (!match) return '';
  const [, year, month, day] = match;
  const date = new Date(`${year}-${month}-${day}T12:00:00+08:00`);
  const weekdays = ['日', '一', '二', '三', '四', '五', '六'];
  return `${year}-${month}-${day} (${weekdays[date.getDay()]})`;
};

const postCardClass = 'glass-panel p-5 text-[var(--text-color)] transition-[border-color,background-color,box-shadow] duration-300 hover:border-[var(--main-color)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_6%,var(--card-color))] hover:shadow-[0_18px_36px_rgba(17,101,154,0.12)]';
const postCategoryClass = 'inline-flex items-center border border-[color:color-mix(in_srgb,var(--main-color)_20%,transparent)] bg-[color:color-mix(in_srgb,var(--main-color)_10%,var(--card-color))] px-2.5 py-1 text-[0.8rem] font-bold tracking-[0.08em] text-[var(--main-color)]';
const metaPillClass = 'inline-flex items-center gap-2 border border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] bg-[color:color-mix(in_srgb,var(--card-color)_68%,transparent)] px-3 py-1 text-[0.86rem] text-[color:color-mix(in_srgb,var(--text-color)_76%,transparent)]';
---

<BaseLayout title="文章" description="博客文章列表" currentPath="/posts">
  <div class="grid grid-cols-[1fr_3fr] items-start gap-3 max-[1280px]:grid-cols-1">
    <PostSidebar categories={categoryItems} />

    <div class="grid grid-cols-1 gap-3">
      {sortedPosts.map((post) => (
        <article>
          <a href={`/posts/${post.slug}`} class:list={[postCardClass, 'group block']}>
            <div class="flex flex-col gap-4">
              <div class="space-y-3">
                <h2 class="m-0 text-[1.42rem] font-bold leading-tight transition-colors duration-300 group-hover:text-[var(--main-color)]">{post.data.title}</h2>
                {post.data.description && <p class="m-0 leading-7 text-[color:color-mix(in_srgb,var(--text-color)_78%,transparent)]">{post.data.description}</p>}
              </div>
              <div class="flex flex-wrap items-center gap-2.5">
                {post.data.category && <span class={postCategoryClass}>{post.data.category}</span>}
                <span class={metaPillClass}>
                  <strong class="font-semibold text-[var(--text-color)]">时间</strong>
                  <time datetime={(post.data.pubDate || post.data.date) ? `${(post.data.pubDate || post.data.date).replace(' ', 'T')}+08:00` : ''}>
                    {formatDate(post.data.pubDate || post.data.date)}
                  </time>
                </span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
