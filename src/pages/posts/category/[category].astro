---
import { getCollection } from 'astro:content';
import DecoratedTitle from '../../../components/DecoratedTitle.astro';
import PostSidebar from '../../../components/PostSidebar.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sortedPosts = posts
    .filter((post) => post.data.pubDate || post.data.date)
    .sort((a, b) => {
      const dateStrA = (a.data.pubDate || a.data.date) as string;
      const dateStrB = (b.data.pubDate || b.data.date) as string;
      const parseDate = (str: string) => {
        const match = str.match(/(\d{4})-(\d{2})-(\d{2})/);
        if (!match) return new Date(0);
        return new Date(`${match[1]}-${match[2]}-${match[3]}T00:00:00+08:00`);
      };
      return parseDate(dateStrB).valueOf() - parseDate(dateStrA).valueOf();
    });

  const categories = [...new Set(sortedPosts.map((post) => post.data.category).filter(Boolean))];
  return categories.map((category) => ({ params: { category } }));
}

const { category } = Astro.params;

const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter((post) => post.data.pubDate || post.data.date)
  .sort((a, b) => {
    const dateStrA = (a.data.pubDate || a.data.date) as string;
    const dateStrB = (b.data.pubDate || b.data.date) as string;
    const parseDate = (str: string) => {
      const match = str.match(/(\d{4})-(\d{2})-(\d{2})/);
      if (!match) return new Date(0);
      return new Date(`${match[1]}-${match[2]}-${match[3]}T00:00:00+08:00`);
    };
    return parseDate(dateStrB).valueOf() - parseDate(dateStrA).valueOf();
  });

const filteredPosts = sortedPosts.filter((post) => post.data.category === category);
const categories = [...new Set(sortedPosts.map((post) => post.data.category).filter(Boolean))];

const formatDate = (dateStr: string | undefined) => {
  if (!dateStr) return '';
  const match = dateStr.match(/(\d{4})-(\d{2})-(\d{2})/);
  if (!match) return '';
  const [, year, month, day] = match;
  const date = new Date(`${year}-${month}-${day}T12:00:00+08:00`);
  const weekdays = ['日', '一', '二', '三', '四', '五', '六'];
  return `${year}-${month}-${day} (${weekdays[date.getDay()]})`;
};

const postLinkClass = 'block bg-[var(--card-color)] p-5 text-[var(--text-color)] transition-colors duration-500 hover:bg-[var(--main-color)] hover:text-[var(--card-color)]';
const postCategoryClass = 'inline-flex rounded px-2 py-0.5 text-sm text-[var(--card-color)] bg-[var(--main-color)] transition-colors duration-500';
const cardClass = 'bg-[var(--card-color)] p-6 max-[576px]:p-5';
---

<BaseLayout title={`${category} - 文章`} description={`分类：${category} 的文章列表`} currentPath="/posts">
  <div class="grid grid-cols-[1fr_3fr] items-start gap-3 max-[1280px]:grid-cols-1">
    <PostSidebar categories={categories} />

    <div class="grid grid-cols-1 gap-2">
      <section class={cardClass}>
        <div class="flex items-center justify-between gap-5 max-[576px]:flex-col max-[576px]:items-start">
          <div class="flex items-center gap-2 text-2xl">
            <svg class="h-6 w-6 fill-[var(--main-color)]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.63 5.84C17.27 5.33 16.67 5 16 5L5 5.01C3.9 5.01 3 5.9 3 7v10c0 1.1.9 1.99 2 1.99L16 19c.67 0 1.27-.33 1.63-.84L22 12l-4.37-6.16z"></path></svg>
            <span class="font-bold">{category}</span>
          </div>
          <div class="flex items-center gap-1 text-sm">
            <svg class="h-4 w-4 fill-[var(--main-color)]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z"></path></svg>
            <span>共 {filteredPosts.length} 篇文章</span>
          </div>
        </div>
      </section>

      {filteredPosts.map((post) => (
        <article class="bg-[var(--card-color)] p-0">
          <a href={`/posts/${post.slug}`} class={`${postLinkClass} group`}>
            <div class="flex flex-col gap-4">
              <h2 class="m-0 text-[1.5em] font-bold">{post.data.title}</h2>
              {post.data.description && <p class="m-0">{post.data.description}</p>}
              <div class="flex flex-wrap items-center gap-2 text-sm">
                {post.data.category && <span class={`${postCategoryClass} group-hover:bg-[var(--card-color)] group-hover:text-[var(--main-color)]`}>{post.data.category}</span>}
                <span class="flex flex-wrap items-center gap-2">
                  <strong>时间:</strong>
                  <time datetime={post.data.pubDate ? `${post.data.pubDate.replace(' ', 'T')}+08:00` : post.data.date ? `${post.data.date.replace(' ', 'T')}+08:00` : ''}>
                    {formatDate(post.data.pubDate || post.data.date)}
                  </time>
                </span>
              </div>
            </div>
          </a>
        </article>
      ))}

      {filteredPosts.length === 0 && (
        <section class={cardClass}>
          <DecoratedTitle>暂无文章</DecoratedTitle>
          <p class="m-0 text-center">该分类下暂无文章</p>
        </section>
      )}
    </div>
  </div>
</BaseLayout>
