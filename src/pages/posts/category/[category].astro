---
import { getCollection } from 'astro:content';
import DecoratedTitle from '../../../components/DecoratedTitle.astro';
import PostCard from '../../../components/PostCard.astro';
import PostSidebar from '../../../components/PostSidebar.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { sortPostsByDate } from '../../../utils/date';
import { getCategoryItems } from '../../../utils/categories';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sortedPosts = sortPostsByDate(posts);

  const categories = [...new Set(sortedPosts.map((post) => post.data.category).filter(Boolean))];
  return categories.map((category) => ({ params: { category } }));
}

const { category } = Astro.params;

const allPosts = await getCollection('blog');
const sortedPosts = sortPostsByDate(allPosts);

const filteredPosts = sortedPosts.filter((post) => post.data.category === category);
const categoryItems = getCategoryItems(sortedPosts);

const panelClass = 'glass-panel';
---

<BaseLayout title={`${category} - 文章`} description={`分类：${category} 的文章列表`} currentPath="/posts" drawerCategories={categoryItems}>
  <div class="grid grid-cols-[1fr_3fr] items-start gap-2 max-[1280px]:grid-cols-1">
    <PostSidebar categories={categoryItems} currentCategory={category} />

    <div class="grid grid-cols-1 gap-2">
      {filteredPosts.map((post) => (
        <PostCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          pubDate={post.data.pubDate}
          date={post.data.date}
        />
      ))}

      {filteredPosts.length === 0 && (
        <section class={panelClass}>
          <DecoratedTitle>暂无文章</DecoratedTitle>
          <p class="m-0 text-center">该分类下暂无文章</p>
        </section>
      )}
    </div>
  </div>
</BaseLayout>
