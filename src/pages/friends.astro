---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { friends, voidFriends } from '../data/friends';

const panelClass = 'glass-panel relative overflow-hidden';
const linkCardClass = 'group relative block h-full overflow-hidden border border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] bg-[color:color-mix(in_srgb,var(--card-color)_72%,transparent)] p-5 text-[var(--text-color)] shadow-[0_10px_30px_rgba(17,101,154,0.08)] backdrop-blur-md transition-[border-color,background-color,box-shadow] duration-300 hover:border-[var(--main-color)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_8%,var(--card-color))] hover:shadow-[0_18px_38px_rgba(17,101,154,0.14)]';
const extractDomain = (url: string) => {
  try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return ''; }
};
const voidLinkCardClass = 'group block h-full border border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] bg-[color:color-mix(in_srgb,var(--card-color)_72%,transparent)] p-4 text-[var(--text-color)] shadow-[0_8px_24px_rgba(17,101,154,0.06)] backdrop-blur-md transition-[border-color,background-color,box-shadow] duration-300 hover:border-[var(--main-color)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_8%,var(--card-color))] hover:shadow-[0_14px_28px_rgba(17,101,154,0.1)]';
const friendShellClass = 'defer-offscreen [--defer-block-size:8.5rem] overflow-hidden text-left';
const voidFriendShellClass = 'defer-offscreen [--defer-block-size:6.5rem] overflow-hidden text-left';
const sectionHeaderClass = 'section-stack';
---

<BaseLayout title="友人" description="友链列表，按 A-Z 顺序排列" currentPath="/friends">
  <div class="grid grid-cols-3 gap-2 max-[1280px]:grid-cols-2 max-[576px]:grid-cols-1">
    <article class="hero-panel col-span-3 max-[1280px]:col-span-2 max-[576px]:col-span-1">
      <div class="relative space-y-3">
        <p class="section-kicker">Yahalo!</p>
        <h2 class="m-0 text-[1.36rem] font-bold leading-[1.35] max-[576px]:text-[1.2rem]">这里是一本名片册，记载在网络上结识的各种朋友</h2>
        <p class="m-0 text-[0.95rem] leading-7 text-[color:color-mix(in_srgb,var(--text-color)_72%,transparent)]">无论你是来自湛蓝晴空 (Bluesky) ，还是来自紫色小象 (Mastodon)，都可以 "Feel free to contact me"</p>
        <p class="m-0 text-[0.95rem] leading-7 text-[color:color-mix(in_srgb,var(--text-color)_72%,transparent)]">按 A-Z 的顺序排列，期待能在茫茫人海中与你共同创造回忆</p>
      </div>
    </article>

    {friends.map((friend) => (
      <article class={friendShellClass}>
        <a href={friend.url} target="_blank" rel="noopener noreferrer" class={linkCardClass}>
          <div class="relative flex h-full items-start gap-4">
            {friend.img && <Image src={friend.img} widths={[80, 160]} sizes="80px" alt={friend.name} class="h-20 w-20 shrink-0 rounded-[1.35rem] object-cover transition-transform duration-300 group-hover:scale-[1.04]" loading="lazy" decoding="async" />}
            <div class="min-w-0 flex-1 self-start pt-0.5">
              <h3 class="m-0 min-w-0 truncate text-[1.08rem] font-bold leading-tight text-[var(--text-color)] transition-colors duration-300 group-hover:text-[var(--main-color)]">{friend.name}</h3>
              <p class="m-0 mt-1 truncate text-sm leading-6 text-[color:color-mix(in_srgb,var(--text-color)_76%,transparent)]">{friend.desc}</p>
              <span class="mt-1.5 inline-flex h-5 max-w-full items-center truncate bg-[color:color-mix(in_srgb,var(--main-color)_14%,var(--card-color))] px-2 text-[0.75rem] text-[color:color-mix(in_srgb,var(--main-color)_30%,var(--text-color))] font-overpass">{extractDomain(friend.url)}</span>
            </div>
          </div>
        </a>
      </article>
    ))}

    <section class:list={[panelClass, 'void-portal col-span-3 space-y-4 max-[1280px]:col-span-2 max-[576px]:col-span-1']}>
      <div class:list={['relative', sectionHeaderClass]}>
        <p class="section-kicker">虚空传送门</p>
        <div class="flex items-center justify-between gap-4">
          <h3 class="m-0 text-[1.36rem] font-bold leading-[1.35] max-[576px]:text-[1.2rem]">这些站点暂时沉睡在虚空中，等待重新上线的那一刻</h3>
          <button type="button" class="void-portal-toggle inline-flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center border-none bg-transparent transition-transform duration-300" aria-expanded="false" aria-label="展开虚空传送门">
            <svg class="h-4 w-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
          </button>
        </div>
      </div>
      <div class="void-portal-content relative overflow-hidden max-h-[9.5rem] transition-[max-height] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]" style="mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 100%);">
        <div class="relative grid grid-cols-4 gap-3 max-[1280px]:grid-cols-3 max-[900px]:grid-cols-2 max-[576px]:grid-cols-1">
          {voidFriends.map((friend) => (
            <article class={voidFriendShellClass}>
              <a href={friend.url} target="_blank" rel="noopener noreferrer" class={voidLinkCardClass}>
                <h3 class="m-0 truncate text-base font-bold leading-tight text-[var(--text-color)] transition-colors duration-300 group-hover:text-[var(--main-color)]">{friend.name}</h3>
                <p class="mt-2 m-0 truncate text-sm leading-6 text-[color:color-mix(in_srgb,var(--text-color)_76%,transparent)]">{friend.desc}</p>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <script>
      let voidPortalCleanup = null;

      function initVoidPortal() {
        voidPortalCleanup?.();
        voidPortalCleanup = null;

        const toggle = document.querySelector('.void-portal-toggle');
        const content = document.querySelector('.void-portal-content');
        if (!toggle || !content) return;

        let expanded = false;
        const COLLAPSED_MASK = 'linear-gradient(to bottom, black 0%, black 40%, transparent 100%)';

        const onClick = () => {
          expanded = !expanded;
          toggle.setAttribute('aria-expanded', String(expanded));
          toggle.style.transform = expanded ? 'rotate(180deg)' : '';

          if (expanded) {
            content.style.maxHeight = content.scrollHeight + 'px';
            content.style.maskImage = 'none';
            content.style.webkitMaskImage = 'none';
          } else {
            content.style.maxHeight = '9.5rem';
            content.style.maskImage = COLLAPSED_MASK;
            content.style.webkitMaskImage = COLLAPSED_MASK;
          }
        };

        toggle.addEventListener('click', onClick);
        voidPortalCleanup = () => toggle.removeEventListener('click', onClick);
      }

      initVoidPortal();
      document.addEventListener('astro:page-load', initVoidPortal);
    </script>
  </div>
</BaseLayout>
