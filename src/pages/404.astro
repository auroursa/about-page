---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout title="404" description="Page Not Found" currentPath="/404">
  <div class="grid grid-cols-1 gap-3">
    <article class:list={['glass-panel relative overflow-hidden text-center']}>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(81,168,221,0.14),transparent_45%)]"></div>
      <div class="relative mx-auto flex max-w-[34rem] flex-col items-center gap-5 py-4">
        <p class="section-kicker">PAGE NOT FOUND</p>
        <div class="space-y-4">
          <h1 class="m-0 text-[5.8rem] font-bold leading-none text-[var(--main-color)] max-[576px]:text-[4.5rem]">404</h1>
          <h2 class="m-0 text-[1.4rem] font-bold leading-tight max-[576px]:text-[1.2rem]">抱歉，你访问的页面不存在</h2>
        </div>
        <p class="m-0 max-w-[30rem] leading-7 text-[color:color-mix(in_srgb,var(--text-color)_78%,transparent)]">可以先回到首页，或者来我的文章页逛逛吧</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/" class="glass-pill-button px-5 text-[0.95rem]">返回首页</a>
          <a href="/posts" class="glass-pill-button px-5 text-[0.95rem]">前往文章</a>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
