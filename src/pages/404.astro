---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout title="404" description="Page Not Found" currentPath="/404">
  <article class="hero-panel">
    <div class="hero-blur -right-8 -top-8"></div>
    <div class="hero-blur -bottom-10 -left-10 !bg-[color:color-mix(in_srgb,var(--main-color)_14%,transparent)]"></div>
    <div class="relative mx-auto flex max-w-[34rem] flex-col items-center gap-5 py-6 text-center">
      <p class="section-kicker">PAGE NOT FOUND</p>
      <div class="space-y-4">
        <h1 class="m-0 text-[5.8rem] font-bold leading-none text-[var(--main-color)] max-[576px]:text-[4.5rem]" style="font-family: 'Overpass', sans-serif;">404</h1>
        <h2 class="m-0 text-[1.36rem] font-bold leading-tight max-[576px]:text-[1.2rem]">抱歉，你访问的页面不存在</h2>
      </div>
      <p class="m-0 max-w-[30rem] text-[0.95rem] leading-7 text-[color:color-mix(in_srgb,var(--text-color)_72%,transparent)]">可以先回到首页，或者来我的文章页逛逛吧</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="glass-pill-button px-5 text-[0.95rem]">返回首页</a>
        <a href="/posts" class="glass-pill-button px-5 text-[0.95rem]">前往文章</a>
      </div>
    </div>
  </article>
</BaseLayout>
