---
import ArticleTimeline from '../components/ArticleTimeline.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHeroPanel from '../components/HomeHeroPanel.astro';
import HomeHeroFeature from '../components/HomeHeroFeature.astro';
import HomeGalleryPanel from '../components/HomeGalleryPanel.astro';
import HomeInfoGrid from '../components/HomeInfoGrid.astro';
import HomeMusicPanel from '../components/HomeMusicPanel.astro';
import HomeProjectPanel from '../components/HomeProjectPanel.astro';
import { homeDeviceItems, homeSkillItems } from '../data/home-info';
import homeStylesUrl from '../styles/home-deferred.css?url';
const siteURL = Astro.site?.origin ?? 'https://cynosura.one';
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Cynosura',
  url: siteURL,
  description: '赤茶的个人页面',
  author: {
    '@type': 'Person',
    name: '赤茶',
    url: `${siteURL}/about`,
  },
};
---

<BaseLayout title="首页" ogImage="/og/page/index.png" currentPath="/" jsonLd={websiteLd}>
  <div class="mb-2 grid grid-cols-[1fr_3fr] items-stretch gap-2 max-[1280px]:grid-cols-1">
    <HomeHeroPanel />
    <HomeHeroFeature />
  </div>

  <link rel="stylesheet" href={homeStylesUrl} />

  <div class="grid grid-cols-1 gap-2">
    <ArticleTimeline />

    <div class="grid grid-cols-2 gap-2 max-[1280px]:grid-cols-1">
      <HomeInfoGrid kicker="技能" title="以 SRE 技能树为主，也许是前端萌新" items={homeSkillItems} />
      <HomeInfoGrid kicker="设备" title="陪我度过了每个抉择的十字路口" items={homeDeviceItems} />
    </div>

    <HomeProjectPanel />

    <HomeMusicPanel />

    <HomeGalleryPanel />
  </div>
  <script src="/js/hero-photo-info.js" defer></script>
</BaseLayout>
