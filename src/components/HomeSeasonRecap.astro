---
import { Image } from 'astro:assets';
import profileAvatar from '../assets/img/profile-avatar.webp';
import { homeGallerySeasonItems } from '../data/home-gallery';
---

<div class="home-gallery-seasons-panel">
  <div class="home-gallery-seasons-head">
    <div class="space-y-2">
      <p class="home-gallery-seasons-kicker">2025 / FOUR SEASONS</p>
      <h4 class="home-gallery-seasons-title">捕捉四季变换的光景，发见细处之美</h4>
    </div>
  </div>

  <div class="home-gallery-seasons-layout">
    <div class="home-gallery-seasons-grid">
      {homeGallerySeasonItems.map((item) => (
        <article class="home-gallery-season-card group">
          <div class="home-gallery-season-image-shell">
            <Image
              class="home-gallery-season-image"
              src={item.src}
              widths={item.widths}
              sizes={item.sizes}
              alt={item.alt}
              loading="lazy"
            />
          </div>
        </article>
      ))}
    </div>

    <article class="home-gallery-post-card" aria-label="2025 四季总结">
      <div class="home-gallery-post-header">
        <Image
          class="home-gallery-post-avatar"
          src={profileAvatar}
          widths={[96, 192, 288]}
          sizes="77px"
          alt="赤茶头像"
        />

        <div class="home-gallery-post-author">
          <strong class="home-gallery-post-name">赤茶</strong>
          <div class="home-gallery-post-author-line">
            <span class="home-gallery-post-handle">@astraorsa</span>
          </div>
        </div>
      </div>

      <div class="home-gallery-post-body">
        <p class="home-gallery-post-text"><span class="home-gallery-post-hashtag">#2025四季总结</span></p>
        <p class="home-gallery-post-text">从春天江岸边的樱花，到夏天走过陌生的古街</p>
        <p class="home-gallery-post-text">在漫长的深秋，抬头遇见一片金黄</p>
        <p class="home-gallery-post-text">直到初冬，城市被圣诞树尖点亮</p>
        <p class="home-gallery-post-text">愿你遇见更美的景色，期待明年更好</p>
      </div>

      <div class="home-gallery-post-meta">
        <span class="home-gallery-post-timestamp">9:41 PM · Dec 31, 2025</span>
        <span class="home-gallery-post-source inline-flex items-center gap-0.5">
          <svg class="h-[0.9rem] w-[0.9rem] shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 21C15.5 17.4 19 14.1764 19 10.2C19 6.22355 15.866 3 12 3C8.13401 3 5 6.22355 5 10.2C5 14.1764 8.5 17.4 12 21Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            <path d="M12 12C13.1046 12 14 11.1046 14 10C14 8.89543 13.1046 8 12 8C10.8954 8 10 8.89543 10 10C10 11.1046 10.8954 12 12 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span>Hangzhou</span>
        </span>
      </div>
    </article>
  </div>
</div>
