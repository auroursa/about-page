---
import AppImage from './AppImage.astro';
import HomeGalleryShuffleScript from './HomeGalleryShuffleScript.astro';
import HomeSeasonRecap from './HomeSeasonRecap.astro';
import { homeGalleryBackdropItems } from '../data/home-gallery';
---

<section class="glass-panel section-panel home-gallery-panel">
  <div class="section-stack">
    <p class="section-kicker">相册</p>
  </div>

  <HomeSeasonRecap />

  <div class="home-gallery-masonry-viewport">
    <div class="home-gallery-masonry" aria-label="摄影瀑布流" data-shuffle-state="pending">
      {homeGalleryBackdropItems.map((item, index) => (
        <figure class="home-gallery-masonry-card group" data-gallery-id={`gallery-${index}`}>
          <div class="home-gallery-masonry-image-shell">
            <AppImage
              preset="cover"
              class="home-gallery-masonry-image"
              src={item.src}
              widths={item.widths}
              sizes={item.sizes}
              alt={item.alt}
              loading="lazy"
            />
          </div>
        </figure>
      ))}
    </div>
  </div>
</section>

<HomeGalleryShuffleScript />
