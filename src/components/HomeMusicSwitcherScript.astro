<script is:inline data-astro-rerun>
  (async () => {
    window.cynosura = window.cynosura ?? {};

    if (typeof window.cynosura.initHomeMusicSwitcher !== 'function') {
      await import('/js/home-music-switcher.js');
    }

    window.cynosura.initHomeMusicSwitcher?.();
  })();
</script>
