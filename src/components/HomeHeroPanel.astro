---
import AppImage from './AppImage.astro';
import profileAvatar from '../assets/img/profile-avatar.webp';
import { getOrderedSocialLinks, getSocialLinkById, heroSocialIconOrder } from '../data/social-links';

const heroSocialIconLinks = getOrderedSocialLinks(heroSocialIconOrder);
const telegramLink = getSocialLinkById('telegram');
const matrixLink = getSocialLinkById('matrix');

if (!telegramLink || !matrixLink) {
  throw new Error('Missing telegram or matrix social link configuration');
}
---

<section class="hero-panel max-[1280px]:hidden">
  <div class="relative space-y-5">
    <div class="flex flex-col items-center gap-4">
      <div class="relative shrink-0">
        <AppImage
          preset="avatar"
          class="h-[5.5rem] w-[5.5rem] rounded-full"
          src={profileAvatar}
          widths={[96, 192, 288]}
          sizes="88px"
          alt="赤茶的头像"
        />
        <a
          href="https://keys.openpgp.org/vks/v1/by-fingerprint/F6006874CC50A6C854B9763C3728385536F22DEA"
          class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full border-2 border-[var(--card-color)] bg-[var(--main-color)] text-white transition-opacity duration-300 opacity-80 hover:opacity-100"
          title="OpenPGP"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="h-3 w-3 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><g><path d="M0 0h24v24H0z" fill="none"></path><path d="M10.758 11.828l7.849-7.849 1.414 1.414-1.414 1.415 2.474 2.474-1.414 1.415-2.475-2.475-1.414 1.414 2.121 2.121-1.414 1.415-2.121-2.122-2.192 2.192a5.002 5.002 0 0 1-7.708 6.294 5 5 0 0 1 6.294-7.708zm-.637 6.293A3 3 0 1 0 5.88 13.88a3 3 0 0 0 4.242 4.242z"></path></g></svg>
        </a>
      </div>
      <div class="space-y-2 text-center">
        <h2 class="m-0 text-[1.5rem] font-bold leading-none">赤茶</h2>
        <p class="m-0 text-[0.92rem] leading-relaxed text-[color:color-mix(in_srgb,var(--text-color)_72%,transparent)] font-overpass">Per aspera, ad astra.</p>
      </div>
    </div>

    <div class="space-y-3">
      <div class="grid grid-cols-5 gap-2">
        {heroSocialIconLinks.map((link) => (
          <a
            class="glass-icon-button h-auto w-full min-w-0 aspect-square"
            href={link.url}
            title={link.title}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <svg class={link.heroIconClass ?? 'h-[1.1rem] w-[1.1rem]'} viewBox={link.viewBox} xmlns="http://www.w3.org/2000/svg" set:html={link.iconBody}></svg>
          </a>
        ))}
      </div>
      <div class="grid grid-cols-2 gap-2">
        <a href={telegramLink.url} class="glass-pill-button" target="_blank" rel="noopener noreferrer">
          <svg class="h-[0.96rem] w-[0.96rem] shrink-0" viewBox="2 8 58 47" xmlns="http://www.w3.org/2000/svg" stroke-width="5.5" stroke="currentColor" fill="none" aria-hidden="true">
            <path d="M26.67,38.57l-.82,11.54A2.88,2.88,0,0,0,28.14,49l5.5-5.26,11.42,8.35c2.08,1.17,3.55.56,4.12-1.92l7.49-35.12h0c.66-3.09-1.08-4.33-3.16-3.55l-44,16.85C6.47,29.55,6.54,31.23,9,32l11.26,3.5L45.59,20.71c1.23-.83,2.36-.37,1.44.44Z" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span>Telegram</span>
        </a>
        <a href={matrixLink.url} class="glass-pill-button" target="_blank" rel="noopener noreferrer">
          <svg class="h-[0.9rem] w-[0.9rem] fill-current" viewBox="0 0 54 54" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M19.4414 3.24C19.4414 1.4506 20.892 0 22.6814 0C34.6108 0 44.2814 9.67065 44.2814 21.6C44.2814 23.3894 42.8308 24.84 41.0414 24.84C39.252 24.84 37.8014 23.3894 37.8014 21.6C37.8014 13.2494 31.032 6.48 22.6814 6.48C20.892 6.48 19.4414 5.0294 19.4414 3.24Z"></path>
            <path fill-rule="evenodd" clip-rule="evenodd" d="M34.5586 50.76C34.5586 52.5494 33.108 54 31.3186 54C19.3893 54 9.71861 44.3294 9.71861 32.4C9.71861 30.6106 11.1692 29.16 12.9586 29.16C14.748 29.16 16.1986 30.6106 16.1986 32.4C16.1986 40.7505 22.9681 47.52 31.3186 47.52C33.108 47.52 34.5586 48.9706 34.5586 50.76Z"></path>
            <path fill-rule="evenodd" clip-rule="evenodd" d="M3.24 34.5601C1.4506 34.5601 0 33.1095 0 31.3201C0 19.3907 9.67065 9.72007 21.6 9.72007C23.3894 9.72007 24.84 11.1707 24.84 12.9601C24.84 14.7495 23.3894 16.2001 21.6 16.2001C13.2495 16.2001 6.48 22.9695 6.48 31.3201C6.48 33.1095 5.0294 34.5601 3.24 34.5601Z"></path>
            <path fill-rule="evenodd" clip-rule="evenodd" d="M50.76 19.4399C52.5494 19.4399 54 20.8905 54 22.6799C54 34.6093 44.3294 44.2799 32.4 44.2799C30.6106 44.2799 29.16 42.8293 29.16 41.0399C29.16 39.2505 30.6106 37.7999 32.4 37.7999C40.7505 37.7999 47.52 31.0305 47.52 22.6799C47.52 20.8905 48.9706 19.4399 50.76 19.4399Z"></path>
          </svg>
          <span>Matrix</span>
        </a>
      </div>
    </div>

    <div class="flex items-center justify-center border-t border-[color:color-mix(in_srgb,var(--text-color)_8%,transparent)] pt-4 text-[0.74rem] text-[color:color-mix(in_srgb,var(--text-color)_60%,transparent)] font-overpass">
      <span class="inline-flex items-start justify-center gap-1.5 tracking-[0.04em] text-center">
        <svg class="mt-[0.08em] h-[0.74rem] w-[0.74rem] shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M3 12h18" stroke-linecap="round"></path>
          <path d="M12 3a13 13 0 0 1 0 18" stroke-linecap="round"></path>
          <path d="M12 3a13 13 0 0 0 0 18" stroke-linecap="round"></path>
        </svg>
        <span>N 30°15′ / E 120°09′</span>
      </span>
    </div>
  </div>
</section>
