---
import { Image } from 'astro:assets';
import profileAvatar from '../assets/img/profile-avatar.webp';
import { socialIconLinks } from '../data/social-links';
---

<section class="hero-panel max-[1280px]:hidden">
  <div class="relative space-y-5">
    <div class="flex flex-col items-center gap-4">
      <Image
        class="h-[5.5rem] w-[5.5rem] rounded-full"
        src={profileAvatar}
        widths={[96, 192, 288]}
        sizes="88px"
        alt="赤茶的头像"
      />
      <div class="space-y-2 text-center">
        <h2 class="m-0 text-[1.5rem] font-bold leading-none">赤茶</h2>
        <p class="m-0 text-[0.92rem] leading-relaxed text-[color:color-mix(in_srgb,var(--text-color)_72%,transparent)] font-overpass">Per aspera, ad astra.</p>
      </div>
    </div>

    <div class="space-y-3">
      <div class="flex justify-center gap-3">
        {socialIconLinks.map((link) => (
          <a
            class="glass-icon-button h-11 w-11"
            href={link.url}
            title={link.title}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <svg class="h-[1.1rem] w-[1.1rem] fill-current" viewBox={link.viewBox} xmlns="http://www.w3.org/2000/svg" set:html={link.iconBody}></svg>
          </a>
        ))}
      </div>
      <div class="grid grid-cols-2 gap-2">
        <a href="https://t.me/looprucha" class="glass-pill-button">Telegram</a>
        <a href="https://matrix.to/#/@froseiun:matrix.org" class="glass-pill-button">Matrix</a>
      </div>
    </div>

    <div class="flex min-w-0 items-center gap-2.5 border-t border-[color:color-mix(in_srgb,var(--text-color)_8%,transparent)] pt-4">
      <a href="https://keys.openpgp.org/vks/v1/by-fingerprint/F6006874CC50A6C854B9763C3728385536F22DEA" class="inline-flex items-center gap-1.5 border border-[color:color-mix(in_srgb,var(--main-color)_16%,transparent)] bg-[color:color-mix(in_srgb,var(--main-color)_6%,var(--card-color))] px-2.5 py-1 transition-all duration-300 hover:border-[color:color-mix(in_srgb,var(--main-color)_32%,transparent)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_12%,var(--card-color))]">
        <svg class="h-3.5 w-3.5 shrink-0 fill-current text-[var(--main-color)]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><g><path d="M0 0h24v24H0z" fill="none"></path><path d="M10.758 11.828l7.849-7.849 1.414 1.414-1.414 1.415 2.474 2.474-1.414 1.415-2.475-2.475-1.414 1.414 2.121 2.121-1.414 1.415-2.121-2.122-2.192 2.192a5.002 5.002 0 0 1-7.708 6.294 5 5 0 0 1 6.294-7.708zm-.637 6.293A3 3 0 1 0 5.88 13.88a3 3 0 0 0 4.242 4.242z"></path></g></svg>
        <span class="text-[0.72rem] font-bold tracking-[0.06em] text-[var(--main-color)]">PGP</span>
      </a>
      <span class="select-all block min-w-0 flex-1 overflow-hidden text-ellipsis whitespace-nowrap text-[0.72rem] leading-none text-[color:color-mix(in_srgb,var(--text-color)_56%,transparent)] font-overpass-mono">3728 3855 36F2 2DEA</span>
    </div>
  </div>
</section>
