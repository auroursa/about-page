---
import { Image } from 'astro:assets';
import profileAvatar from '../assets/img/profile-avatar.webp';

interface Props {
  categories: Array<{
    name: string;
    count: number;
  }>;
  currentCategory?: string;
}

const { categories, currentCategory } = Astro.props;

const categoryListClass = 'space-y-2';
const categoryLinkClass = 'flex min-h-10 items-center justify-between border border-[color:color-mix(in_srgb,var(--text-color)_10%,transparent)] bg-[color:color-mix(in_srgb,var(--card-color)_68%,transparent)] px-4 py-2 text-[0.95rem] text-[var(--text-color)] transition-[border-color,background-color,color,box-shadow] duration-300 hover:border-[var(--main-color)] hover:bg-[color:color-mix(in_srgb,var(--main-color)_8%,var(--card-color))] hover:text-[var(--main-color)] hover:shadow-[0_10px_24px_rgba(17,101,154,0.08)]';
const categoryLinkActiveClass = 'border-[var(--main-color)] bg-[color:color-mix(in_srgb,var(--main-color)_10%,var(--card-color))] text-[var(--main-color)] shadow-[0_10px_24px_rgba(17,101,154,0.08)]';
const categoryPillWrapClass = 'hidden flex-wrap items-center gap-2 max-[1280px]:flex';
const categoryPillClass = 'glass-pill-button min-h-9 px-3 py-1.5 text-[0.9rem]';
const categoryPillActiveClass = 'border-[var(--main-color)] bg-[color:color-mix(in_srgb,var(--main-color)_10%,var(--card-color))] text-[var(--main-color)] shadow-[0_10px_24px_rgba(17,101,154,0.08)]';
---

<aside class="hero-panel sticky top-[4.75rem] space-y-5 text-center max-[1280px]:hidden">
  <div class="relative space-y-5">
    <div class="flex flex-col items-center gap-4">
      <Image
        class="h-[5.5rem] w-[5.5rem] rounded-full"
        src={profileAvatar}
        widths={[96, 192, 288]}
        sizes="88px"
        alt="赤茶的头像"
      />
      <div class="space-y-2 text-center">
        <h2 class="m-0 text-[1.5rem] font-bold leading-none">赤茶</h2>
        <p class="m-0 text-[0.92rem] leading-relaxed text-[color:color-mix(in_srgb,var(--text-color)_72%,transparent)] font-overpass">Per aspera, ad astra.</p>
      </div>
    </div>

    <div class="space-y-4 max-[1280px]:text-left max-[576px]:text-center">
      {categories.length > 0 && (
        <>
          <div>
            <div class:list={[categoryListClass, 'max-[1280px]:hidden']}>
              {categories.map((cat) => (
                <a href={`/posts/category/${encodeURIComponent(cat.name)}`} class:list={[categoryLinkClass, currentCategory === cat.name && categoryLinkActiveClass]}>
                  <span>{cat.name}</span>
                  <span class="text-[0.82rem] text-[color:color-mix(in_srgb,currentColor_70%,transparent)]">{cat.count}</span>
                </a>
              ))}
            </div>
            <div class={categoryPillWrapClass}>
              {categories.map((cat) => (
                <a href={`/posts/category/${encodeURIComponent(cat.name)}`} class:list={[categoryPillClass, currentCategory === cat.name && categoryPillActiveClass]}>
                  {cat.name}
                  <span class="ml-1 text-[0.8rem] text-[color:color-mix(in_srgb,currentColor_72%,transparent)]">{cat.count}</span>
                </a>
              ))}
            </div>
          </div>
        </>
      )}

      <div class="flex justify-center pt-1 max-[1280px]:justify-start max-[1280px]:pt-0">
        <a class="glass-icon-button h-11 w-11" href="/rss.xml" title="RSS Feed" aria-label="RSS Feed" data-astro-reload>
          <svg class="h-[1.1rem] w-[1.1rem] fill-current" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 0h48v48H0z" fill="none"></path>
            <circle cx="12.36" cy="35.64" r="4.36"></circle>
            <path d="M8 8.89v5.66c14.06 0 25.46 11.4 25.46 25.46h5.66C39.11 22.82 25.18 8.89 8 8.89zM8 20.2v5.66c7.81 0 14.14 6.34 14.14 14.14h5.66c0-10.93-8.87-19.8-19.8-19.8z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</aside>
