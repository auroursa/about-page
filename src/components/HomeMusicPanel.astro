---
import { homeMusicAppleLinks } from '../data/home-music';
import HomeMusicSwitcherScript from './HomeMusicSwitcherScript.astro';
import { readFileSync, writeFileSync, mkdirSync } from 'node:fs';
import { resolve } from 'node:path';

interface AppleMusicCard {
  link: string;
  previewUrl: string | null;
  title: string;
  artist: string;
  artwork: string | null;
  artworkThumb: string | null;
  year: string;
  genre: string;
  trackNumber: number | null;
  trackCount: number | null;
  releaseType: 'single' | 'album';
  accent: string;
}

interface AppleLookupResult {
  wrapperType?: string;
  artistName?: string;
  artworkUrl100?: string;
  artworkUrl60?: string;
  collectionId?: number;
  collectionType?: string;
  collectionName?: string;
  copyright?: string;
  kind?: string;
  previewUrl?: string;
  primaryGenreName?: string;
  releaseDate?: string;
  trackNumber?: number;
  trackCount?: number;
  trackName?: string;
  isStreamable?: boolean;
}

interface ParsedAppleIds {
  trackId: string | null;
  collectionId: string | null;
}

const musicAccentPalette = [
  '194 88% 46%',
  '164 76% 39%',
  '204 83% 44%',
  '28 90% 52%',
  '352 78% 48%',
  '14 82% 53%',
] as const;

const hashToAccent = (seed: string): string => {
  let hash = 0;

  for (let index = 0; index < seed.length; index += 1) {
    hash = (hash * 33 + seed.charCodeAt(index)) >>> 0;
  }

  return musicAccentPalette[hash % musicAccentPalette.length];
};

const toReleaseYear = (source?: string, copyright?: string): string => {
  if (!source) {
    const fromCopyright = copyright?.match(/(19|20)\d{2}/)?.[0];
    return fromCopyright ?? '年份未知';
  }

  const parsed = new Date(source);

  if (Number.isNaN(parsed.getTime())) {
    return '年份未知';
  }

  return String(parsed.getUTCFullYear());
};

const toReleaseType = (collectionType?: string, trackCount?: number): 'single' | 'album' => {
  if (typeof trackCount === 'number') {
    if (trackCount <= 1) {
      return 'single';
    }

    return 'album';
  }

  if (collectionType?.toLowerCase() === 'album') {
    return 'album';
  }

  return 'single';
};

const formatTrackMeta = (
  releaseType: 'single' | 'album',
  trackNumber: number | null,
  trackCount: number | null,
): string | null => {
  if (releaseType !== 'album') {
    return null;
  }

  if (typeof trackCount === 'number' && trackCount > 1) {
    if (typeof trackNumber === 'number' && trackNumber > 0) {
      return `排序 ${trackNumber}/${trackCount}`;
    }

    return `排序 ${trackCount} 首`;
  }

  return null;
};

const parseAppleIds = (link: string): ParsedAppleIds => {
  try {
    const parsed = new URL(link);
    const idInQuery = parsed.searchParams.get('i');
    const pathSegments = parsed.pathname.split('/').filter(Boolean);
    const numericSegments = pathSegments.filter((segment) => /^\d+$/.test(segment));
    const idInPath = parsed.pathname.match(/id(\d+)/)?.[1] ?? null;
    const plainNumericPathId = numericSegments.length > 0 ? numericSegments[numericSegments.length - 1] : null;

    const collectionId =
      (plainNumericPathId && /^\d+$/.test(plainNumericPathId) ? plainNumericPathId : null) ??
      (idInPath && /^\d+$/.test(idInPath) ? idInPath : null);
    const trackId = idInQuery && /^\d+$/.test(idInQuery)
      ? idInQuery
      : collectionId;

    return { trackId, collectionId };
  } catch {
    return { trackId: null, collectionId: null };
  }
};

const toSizedArtwork = (url: string, size: number): string => {
  return url.replace(/\d+x\d+bb/g, `${size}x${size}bb`);
};

const resolveAppleMusicCard = async (link: string): Promise<AppleMusicCard> => {
  const { trackId, collectionId } = parseAppleIds(link);
  const fallbackAccent = hashToAccent(link);

  if (!trackId) {
      return {
        link,
        title: 'Music',
        artist: '链接格式暂不支持',
        previewUrl: null,
        artwork: null,
        artworkThumb: null,
        year: '年份未知',
        genre: '流派未标注',
        trackNumber: null,
        trackCount: null,
        releaseType: 'single',
        accent: fallbackAccent,
      };
  }

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);

  try {
    const trackRequest = fetch(`https://itunes.apple.com/lookup?id=${trackId}&country=cn&entity=song`, {
      signal: controller.signal,
    });
    const collectionRequest = collectionId && collectionId !== trackId
      ? fetch(`https://itunes.apple.com/lookup?id=${collectionId}&country=cn&entity=album`, {
          signal: controller.signal,
        })
      : null;
    const [trackResponse, collectionResponse] = await Promise.all([
      trackRequest,
      collectionRequest,
    ]);

    if (!trackResponse.ok || (collectionResponse && !collectionResponse.ok)) {
      throw new Error('Lookup failed');
    }

    const trackPayload = await trackResponse.json();
    const trackResults = Array.isArray(trackPayload?.results) ? (trackPayload.results as AppleLookupResult[]) : [];
    const collectionPayload = collectionResponse ? await collectionResponse.json() : null;
    const collectionResults = Array.isArray(collectionPayload?.results) ? (collectionPayload.results as AppleLookupResult[]) : [];
    const matched =
      trackResults.find((item) => item.kind === 'song') ??
      trackResults.find((item) => item.wrapperType === 'track') ??
      trackResults[0];
    const collection =
      collectionResults.find((item) => item.wrapperType === 'collection') ??
      trackResults.find((item) => item.wrapperType === 'collection') ??
      trackResults.find((item) => typeof item.trackCount === 'number');

    if (!matched) {
      throw new Error('No lookup result');
    }

    const artworkSource = matched.artworkUrl100 ?? matched.artworkUrl60;
    const trackCount =
      typeof collection?.trackCount === 'number'
        ? collection.trackCount
        : typeof matched.trackCount === 'number'
          ? matched.trackCount
          : null;
    const trackNumber = typeof matched.trackNumber === 'number' ? matched.trackNumber : null;
    const releaseType = toReleaseType(matched.collectionType ?? collection?.collectionType, trackCount ?? undefined);
    const year = toReleaseYear(collection?.releaseDate ?? matched.releaseDate, collection?.copyright ?? matched.copyright);
    const genre = collection?.primaryGenreName ?? matched.primaryGenreName ?? '流派未标注';
    const title = matched.trackName ?? matched.collectionName ?? 'Music';
    const artist = matched.artistName ?? '未知艺术家';

    const streamable = matched.isStreamable !== false;
    const previewUrl = streamable && matched.previewUrl ? matched.previewUrl : null;

    return {
      link,
      title,
      artist,
      previewUrl,
      artwork: artworkSource ? toSizedArtwork(artworkSource, 600) : null,
      artworkThumb: artworkSource ? toSizedArtwork(artworkSource, 120) : null,
      year,
      genre,
      trackNumber,
      trackCount,
      releaseType,
      accent: hashToAccent(`${title}-${artist}`),
    };
  } catch {
    return {
      link,
      title: 'Music',
      artist: '封面抓取失败，点击跳转查看',
      previewUrl: null,
      artwork: null,
      artworkThumb: null,
      year: '年份未知',
      genre: '流派未标注',
      trackNumber: null,
      trackCount: null,
      releaseType: 'single',
      accent: fallbackAccent,
    };
  } finally {
    clearTimeout(timeout);
  }
};

/* ── Build-time file cache (24 h TTL) ── */

const CACHE_TTL_MS = 24 * 60 * 60 * 1000;
const cacheDir = resolve('.cache');
const cacheFile = resolve(cacheDir, 'music-metadata.json');

interface MusicCache {
  ts: number;
  cards: Record<string, AppleMusicCard>;
}

const loadCache = (): MusicCache => {
  try {
    const raw = readFileSync(cacheFile, 'utf-8');
    return JSON.parse(raw) as MusicCache;
  } catch {
    return { ts: 0, cards: {} };
  }
};

const saveCache = (cache: MusicCache): void => {
  try {
    mkdirSync(cacheDir, { recursive: true });
    writeFileSync(cacheFile, JSON.stringify(cache, null, 2), 'utf-8');
  } catch {
    // non-fatal — cache write failure is fine
  }
};

const cachedResolve = async (links: string[]): Promise<AppleMusicCard[]> => {
  const cache = loadCache();
  const isStale = Date.now() - cache.ts > CACHE_TTL_MS;
  const results: AppleMusicCard[] = [];
  const toFetch: { index: number; link: string }[] = [];

  for (let i = 0; i < links.length; i += 1) {
    const hit = cache.cards[links[i]];

    if (!isStale && hit) {
      results[i] = hit;
    } else {
      toFetch.push({ index: i, link: links[i] });
    }
  }

  if (toFetch.length > 0) {
    const fresh = await Promise.all(toFetch.map(({ link }) => resolveAppleMusicCard(link)));

    for (let j = 0; j < toFetch.length; j += 1) {
      results[toFetch[j].index] = fresh[j];
      cache.cards[toFetch[j].link] = fresh[j];
    }

    cache.ts = Date.now();
    saveCache(cache);
  }

  return results;
};

const musicCards = await cachedResolve(homeMusicAppleLinks);
const featuredMusic = musicCards[0] ?? null;
const featuredTrackMeta =
  featuredMusic
    ? formatTrackMeta(featuredMusic.releaseType, featuredMusic.trackNumber, featuredMusic.trackCount)
    : null;
const featuredHasPreview = Boolean(featuredMusic?.previewUrl);
---

<section class="glass-panel section-panel home-music-panel">
  <div class="section-stack home-music-head">
    <p class="section-kicker">音乐</p>
    <h3 class="section-title">最近常在耳畔停驻的旋律</h3>
  </div>

  {
    featuredMusic ? (
      <div class="home-music-layout" data-home-music style={`--music-accent: ${featuredMusic.accent};`}>
        <article class="home-music-feature">
          <a
            class="home-music-feature-cover-link"
            href={featuredMusic.link}
            target="_blank"
            rel="noopener noreferrer"
            data-music-cover-link
            aria-label={`打开 ${featuredMusic.title} 的 Apple Music 页面（新窗口）`}
          >
            <div class="home-music-feature-cover-shell">
              <div class="home-music-feature-cover-frame">
                <img
                  class="home-music-feature-cover"
                  src={featuredMusic.artwork ?? ''}
                  width="600"
                  height="600"
                  alt={`${featuredMusic.title} 专辑封面`}
                  loading="eager"
                  decoding="async"
                  crossorigin="anonymous"
                  referrerpolicy="no-referrer"
                  data-music-cover-img
                  hidden={!featuredMusic.artwork}
                />
                <div class="home-music-feature-cover home-music-cover-fallback" aria-hidden="true" data-music-cover-fallback hidden={Boolean(featuredMusic.artwork)}>AM</div>
              </div>
            </div>
          </a>
          <div class="home-music-feature-meta">
            <div class="home-music-feature-meta-top">
              <div class="home-music-feature-main-text">
                <p class="home-music-feature-title" data-music-cover-title>{featuredMusic.title}</p>
                <p class="home-music-feature-artist" data-music-cover-artist>{featuredMusic.artist}</p>
              </div>
              <button
                type="button"
                class="home-music-feature-play"
                data-music-play-toggle
                aria-label={featuredHasPreview ? `播放 ${featuredMusic.title} 的试听片段` : '当前曲目暂无试听'}
                aria-pressed="false"
                disabled={!featuredHasPreview}
              >
                <svg class="home-music-feature-play-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path class="home-music-play-path" d="M8 5.5v13l10-6.5z" fill="currentColor" />
                  <g class="home-music-pause-path">
                    <rect x="6.5" y="5" width="3.5" height="14" rx="0.8" fill="currentColor" />
                    <rect x="14" y="5" width="3.5" height="14" rx="0.8" fill="currentColor" />
                  </g>
                </svg>
              </button>
            </div>
            <div class="home-music-feature-subline">
              <div class="home-music-feature-detail-group">
                <span class="home-music-feature-detail-chip" data-music-cover-year>{featuredMusic.year}</span>
                <span class="home-music-feature-detail-chip" data-music-cover-genre>{featuredMusic.genre}</span>
              </div>
              <div class="home-music-feature-tags" aria-hidden="true">
                <span class="home-music-feature-tag" data-music-cover-tag-type>{featuredMusic.releaseType === 'album' ? '专辑' : '单曲'}</span>
                <span class="home-music-feature-tag" data-music-cover-tag-count hidden={!featuredTrackMeta}>{featuredTrackMeta}</span>
              </div>
            </div>
          </div>
        </article>

        <ul class="home-music-list" aria-label="最近常听曲目">
          {musicCards.map((item, index) => (
            <li>
              <button
                type="button"
                class:list={['home-music-list-item', index === 0 && 'is-active']}
                aria-pressed={index === 0 ? 'true' : 'false'}
                data-music-item
                data-link={item.link}
                data-title={item.title}
                data-artist={item.artist}
                data-artwork={item.artwork ?? ''}
                data-year={item.year}
                data-genre={item.genre}
                data-release-type={item.releaseType}
                data-preview-url={item.previewUrl ?? ''}
                data-track-number={item.trackNumber !== null ? String(item.trackNumber) : ''}
                data-track-count={item.trackCount !== null ? String(item.trackCount) : ''}
                data-accent={item.accent}
              >
                {
                  item.artworkThumb ? (
                    <img
                      class="home-music-list-thumb"
                      src={item.artworkThumb}
                      width="80"
                      height="80"
                      alt=""
                      loading="lazy"
                      decoding="async"
                      referrerpolicy="no-referrer"
                      aria-hidden="true"
                    />
                  ) : (
                    <span class="home-music-list-thumb home-music-list-thumb-fallback" aria-hidden="true">AM</span>
                  )
                }
                <span class="home-music-list-text">
                  <span class="home-music-list-title">{item.title}</span>
                  <span class="home-music-list-artist">{item.artist}</span>
                </span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <p class="home-music-empty">先把 Apple Music 链接填到数据里，音乐卡片就会自动生成。</p>
    )
  }
</section>

{featuredMusic && <HomeMusicSwitcherScript />}
