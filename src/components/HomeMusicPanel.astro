---
import { homeMusicAppleLinks } from '../data/home-music';
import HomeMusicSwitcherScript from './HomeMusicSwitcherScript.astro';

interface AppleMusicCard {
  link: string;
  title: string;
  artist: string;
  artwork: string | null;
  artworkThumb: string | null;
}

interface AppleLookupResult {
  artistName?: string;
  artworkUrl100?: string;
  artworkUrl60?: string;
  collectionName?: string;
  kind?: string;
  trackName?: string;
}

const parseTrackId = (link: string): string | null => {
  try {
    const parsed = new URL(link);
    const idInQuery = parsed.searchParams.get('i');

    if (idInQuery && /^\d+$/.test(idInQuery)) {
      return idInQuery;
    }

    const idInPath = parsed.pathname.match(/id(\d+)/)?.[1] ?? null;
    return idInPath;
  } catch {
    return null;
  }
};

const toSizedArtwork = (url: string, size: number): string => {
  return url.replace(/\d+x\d+bb/g, `${size}x${size}bb`);
};

const resolveAppleMusicCard = async (link: string): Promise<AppleMusicCard> => {
  const trackId = parseTrackId(link);

  if (!trackId) {
      return {
        link,
        title: 'Music',
        artist: '链接格式暂不支持',
        artwork: null,
        artworkThumb: null,
      };
  }

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);

  try {
    const response = await fetch(`https://itunes.apple.com/lookup?id=${trackId}&country=cn&entity=song`, {
      signal: controller.signal,
    });

    if (!response.ok) {
      throw new Error('Lookup failed');
    }

    const payload = await response.json();
    const results = Array.isArray(payload?.results) ? (payload.results as AppleLookupResult[]) : [];
    const matched = results.find((item) => item.kind === 'song') ?? results[0];

    if (!matched) {
      throw new Error('No lookup result');
    }

    const artworkSource = matched.artworkUrl100 ?? matched.artworkUrl60;

    return {
      link,
      title: matched.trackName ?? matched.collectionName ?? 'Music',
      artist: matched.artistName ?? '未知艺术家',
      artwork: artworkSource ? toSizedArtwork(artworkSource, 600) : null,
      artworkThumb: artworkSource ? toSizedArtwork(artworkSource, 120) : null,
    };
  } catch {
    return {
      link,
      title: 'Music',
      artist: '封面抓取失败，点击跳转查看',
      artwork: null,
      artworkThumb: null,
    };
  } finally {
    clearTimeout(timeout);
  }
};

const musicCards = await Promise.all(homeMusicAppleLinks.map((link) => resolveAppleMusicCard(link)));
const featuredMusic = musicCards[0] ?? null;
---

<section class="glass-panel section-panel home-music-panel">
  <div class="section-stack home-music-head">
    <p class="section-kicker">音乐</p>
    <h3 class="section-title">一些最近循环常听的旋律</h3>
  </div>

  {
    featuredMusic ? (
      <div class="home-music-layout" data-home-music>
        <a
          class="home-music-feature"
          href={featuredMusic.link}
          target="_blank"
          rel="noopener noreferrer"
          data-music-cover-link
          aria-label={`打开 ${featuredMusic.title} 的 Apple Music 页面（新窗口）`}
        >
          <div class="home-music-feature-cover-shell">
            <div class="home-music-feature-cover-frame">
              <img
                class="home-music-feature-cover"
                src={featuredMusic.artwork ?? ''}
                width="600"
                height="600"
                alt={`${featuredMusic.title} 专辑封面`}
                loading="lazy"
                decoding="async"
                referrerpolicy="no-referrer"
                data-music-cover-img
                hidden={!featuredMusic.artwork}
              />
              <div class="home-music-feature-cover home-music-cover-fallback" aria-hidden="true" data-music-cover-fallback hidden={Boolean(featuredMusic.artwork)}>AM</div>
              <span class="home-music-feature-badge" aria-hidden="true">
                <svg class="home-music-feature-badge-icon" viewBox="-1.5 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <g fill="currentColor" fill-rule="evenodd">
                    <g transform="translate(-102 -7439)">
                      <g transform="translate(56 160)">
                        <path d="M57.5708873,7282.19296 C58.2999598,7281.34797 58.7914012,7280.17098 58.6569121,7279 C57.6062792,7279.04 56.3352055,7279.67099 55.5818643,7280.51498 C54.905374,7281.26397 54.3148354,7282.46095 54.4735932,7283.60894 C55.6455696,7283.69593 56.8418148,7283.03894 57.5708873,7282.19296 M60.1989864,7289.62485 C60.2283111,7292.65181 62.9696641,7293.65879 63,7293.67179 C62.9777537,7293.74279 62.562152,7295.10677 61.5560117,7296.51675 C60.6853718,7297.73474 59.7823735,7298.94772 58.3596204,7298.97372 C56.9621472,7298.99872 56.5121648,7298.17973 54.9134635,7298.17973 C53.3157735,7298.17973 52.8162425,7298.94772 51.4935978,7298.99872 C50.1203933,7299.04772 49.0738052,7297.68074 48.197098,7296.46676 C46.4032359,7293.98379 45.0330649,7289.44985 46.8734421,7286.3899 C47.7875635,7284.87092 49.4206455,7283.90793 51.1942837,7283.88393 C52.5422083,7283.85893 53.8153044,7284.75292 54.6394294,7284.75292 C55.4635543,7284.75292 57.0106846,7283.67793 58.6366882,7283.83593 C59.3172232,7283.86293 61.2283842,7284.09893 62.4549652,7285.8199 C62.355868,7285.8789 60.1747177,7287.09489 60.1989864,7289.62485"></path>
                      </g>
                    </g>
                  </g>
                </svg>
                <span class="home-music-feature-badge-text">Music</span>
              </span>
            </div>
          </div>
          <div class="home-music-feature-meta">
            <p class="home-music-feature-title" data-music-cover-title>{featuredMusic.title}</p>
            <p class="home-music-feature-artist" data-music-cover-artist>{featuredMusic.artist}</p>
          </div>
        </a>

        <ul class="home-music-list" aria-label="最近常听曲目">
          {musicCards.map((item, index) => (
            <li>
              <button
                type="button"
                class:list={['home-music-list-item', index === 0 && 'is-active']}
                aria-pressed={index === 0 ? 'true' : 'false'}
                data-music-item
                data-link={item.link}
                data-title={item.title}
                data-artist={item.artist}
                data-artwork={item.artwork ?? ''}
              >
                {
                  item.artworkThumb ? (
                    <img
                      class="home-music-list-thumb"
                      src={item.artworkThumb}
                      width="80"
                      height="80"
                      alt=""
                      loading="lazy"
                      decoding="async"
                      referrerpolicy="no-referrer"
                      aria-hidden="true"
                    />
                  ) : (
                    <span class="home-music-list-thumb home-music-list-thumb-fallback" aria-hidden="true">AM</span>
                  )
                }
                <span class="home-music-list-text">
                  <span class="home-music-list-title">{item.title}</span>
                  <span class="home-music-list-artist">{item.artist}</span>
                </span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <p class="home-music-empty">先把 Apple Music 链接填到数据里，音乐卡片就会自动生成。</p>
    )
  }
</section>

{featuredMusic && <HomeMusicSwitcherScript />}
