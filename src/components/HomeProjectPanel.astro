---
import AppImage from './AppImage.astro';
import blueskyLogo from '../assets/img/bluesky-logo.svg';
import cleartextLogo from '../assets/img/cleartext-logo.jpg';
---

<section class="glass-panel section-panel">
  <div class="section-stack">
    <p class="section-kicker">项目</p>
    <h3 class="section-title">做一些对世界温柔的小事</h3>
  </div>

  <div class="project-card-list">
    <a href="https://github.com/bluesky-social/social-app" target="_blank" rel="noopener noreferrer" class="project-card" aria-label="打开 Bluesky social-app 项目首页（新窗口）">
      <div class="project-card-stack">
        <div class="project-brand">
          <AppImage src={blueskyLogo} width={20} height={18} alt="Bluesky" class="project-logo" loading="lazy" decoding="async" />
          <p class="project-name">Bluesky App</p>
        </div>
        <p class="project-summary">贡献 CJK 本地化相关代码改进<br />担任简体中文、繁体中文及粤文的本地化 Proofreader</p>
        <div class="project-tag-row">
          <span class="glass-info-tag">TypeScript</span>
          <span class="glass-info-tag">React Native</span>
          <span class="glass-info-tag">Node.js</span>
        </div>
      </div>
    </a>

    <a href="https://cleartext.sh" target="_blank" rel="noopener noreferrer" class="project-card" aria-label="打开 Cleartext 项目首页（新窗口）">
      <div class="project-card-stack">
        <div class="project-brand">
          <AppImage
            src={cleartextLogo}
            widths={[32, 64, 128]}
            sizes="18px"
            alt="Cleartext"
            class="project-logo"
            loading="lazy"
            decoding="async"
          />
          <p class="project-name">Cleartext</p>
        </div>
        <p class="project-summary">在原页读懂另一种语言<br />把翻译留在页面里，把隐私留在你手里</p>
        <div class="project-tag-row">
          <span class="glass-info-tag">Browser Extension</span>
          <span class="glass-info-tag">Privacy-First</span>
          <span class="glass-info-tag">BYOK</span>
        </div>
      </div>
    </a>
  </div>
</section>
