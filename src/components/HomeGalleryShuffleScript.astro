<script is:inline data-astro-rerun>
  (async () => {
    window.cynosura = window.cynosura ?? {};

    if (typeof window.cynosura.initHomeGalleryShuffle !== 'function') {
      await import('/js/home-gallery-shuffle.js');
    }

    window.cynosura.initHomeGalleryShuffle?.();
  })();
</script>
